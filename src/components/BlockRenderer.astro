---
import AnswerCapsule from './AnswerCapsule.astro';
import CanCant from './CanCant.astro';
import Stepper from './Stepper.astro';
import FactGrid from './FactGrid.astro';
import TopicGrid from './TopicGrid.astro';
import PriceCard from './PriceCard.astro';
import Note from './Note.astro';
import Faq from './Faq.astro';
import Credentials from './Credentials.astro';
import VerifiedSources from './VerifiedSources.astro';
import Prose from './Prose.astro';
import type { BlockData } from '../content.config';

// THE REGISTRY. One line per content shape. This is the only place the
// shape -> component decision is encoded, so it reviews in a single screen.
const registry: Record<BlockData['type'], any> = {
  capsule: AnswerCapsule,
  prose: Prose,
  cancant: CanCant,
  stepper: Stepper,
  facts: FactGrid,
  topics: TopicGrid,
  price: PriceCard,
  note: Note,
  faq: Faq,
  credentials: Credentials,
  verified: VerifiedSources,
};

interface Props { block: BlockData; }
const { block } = Astro.props;

// Components that take their body through <slot> (AnswerCapsule, Note, Prose)
// get it as children. Prop-only components ignore empty children, so no existing
// component file needs to change.
const { type, html, ...props } = block as any;
const Cmp = registry[type];
---
{html
  ? <Cmp {...props}><Fragment set:html={html} /></Cmp>
  : <Cmp {...props} />}
