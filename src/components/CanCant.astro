---
interface Props { canTitle: string; can: string[]; cantTitle: string; cant: string[]; }
const { canTitle, can, cantTitle, cant } = Astro.props;
---
<div class="cancan">
  <div class="can-col can">
    <p class="can-h">{canTitle}</p>
    <ul>
      {can.map((li) => (
        <li><span class="gl" aria-hidden="true">✓</span><span set:html={li} /></li>
      ))}
    </ul>
  </div>
  <div class="can-col cant">
    <p class="can-h">{cantTitle}</p>
    <ul>
      {cant.map((li) => (
        <li><span class="gl" aria-hidden="true">✕</span><span set:html={li} /></li>
      ))}
    </ul>
  </div>
</div>
