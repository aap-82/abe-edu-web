---
import Placeholder from './Placeholder.astro';
import type { Person } from '../types/course';
// Two-profile E-E-A-T block: developer + reviewer. Grayscale portraits; if a portrait is missing,
// keep the FPO placeholder and do NOT add `image` to Person schema.
//
// `org` fills the DEVELOPER slot with an organisation instead of a person. On an asqa-accredited
// page the course is developed and owned by the RTO partner (not any ABE person, see
// kb/rules/authority-model.md §6), so the developer card is the RTO: a monogram badge carrying its
// number instead of a portrait, its role and scope as the credential list, and a training.gov.au
// verify link instead of a LinkedIn/bio. It renders FIRST, so the pairing reads developer → reviewer
// exactly as the two-person version did.
interface OrgCard {
  name: string; legalName?: string; rtoNumber?: string; role: string;
  blurb?: string; scopeNote?: string; tgaUrl?: string; verified?: string; url?: string;
  email?: string; phone?: string;
}
interface Props { people: Person[]; org?: OrgCard; }
const { people, org } = Astro.props;
// Credentials arrive as one " · "-joined string. They used to render as that same run-on
// line with the separators recoloured, which put four distinct claims into a single
// paragraph sitting directly above three paragraphs of bio, at similar weight. The
// credentials are the load-bearing content on a trust block, and they dissolved into the
// prose. Split into real list items instead: scannable, and structurally distinct from the
// bio below it.
const credList = (s: string) => s.split(' · ').map((c) => c.trim()).filter(Boolean);

// Two-tone credential lines: a primary phrase in darker grey, a trailing detail in lighter grey,
// with a middot divider between them. Person creds read "Role, Organisation", so split at the last
// comma (a line with no comma stays a single primary phrase; deliberately not splitting award/title
// lines on " for "). Scope notes read "White Card (unit X) for QLD, WA and TAS", so split at " for "
// to send the states to the lighter tone while keeping their internal comma list intact.
type Dual = [string, string | null];
const dualComma = (s: string): Dual => { const i = s.lastIndexOf(', '); return i > 0 ? [s.slice(0, i), s.slice(i + 2)] : [s, null]; };
const dualFor = (s?: string): Dual | null => { if (!s) return null; const i = s.indexOf(' for '); return i > 0 ? [s.slice(0, i), s.slice(i + 5)] : [s, null]; };
const orgCreds: Dual[] = [
  org?.rtoNumber ? ['Registered training organisation', `RTO ${org.rtoNumber}`] as Dual : null,
  ['Accredited by the Australian Skills Quality Authority (ASQA)', null] as Dual,
  dualFor(org?.scopeNote),
].filter((x): x is Dual => x !== null);
---
<div class="people">
  {org && (
    <div class="person person-org">
      <div class="org-badge ph r45" aria-hidden="true">
        <span class="rb-k">RTO</span>
        <span class="rb-n num">{org.rtoNumber}</span>
      </div>
      <div>
        <h3 class="h3">{org.legalName ?? org.name}</h3>
        <p class="role">{org.role}</p>
        <ul class="cred-list" role="list">
          {orgCreds.map(([a, b]) => (
            <li>
              <span class="cl-a" set:html={a} />
              {b && <><span class="cl-sep" aria-hidden="true"> · </span><span class="cl-b" set:html={b} /></>}
            </li>
          ))}
        </ul>
        {org.blurb && <p>{org.blurb}</p>}
        {(org.email || org.phone) && (
          <p class="org-contact">
            {org.email && <a class="pl" href={`mailto:${org.email}`}>{org.email}</a>}
            {org.phone && <a class="pl pl-2" href={`tel:${org.phone.replace(/\s+/g, '')}`}>{org.phone}</a>}
          </p>
        )}
        <p class="p-links">
          {org.tgaUrl && <a class="pl" href={org.tgaUrl} rel="noopener">Verify on training.gov.au →</a>}
          {org.url && <a class="pl pl-2" href={org.url} rel="noopener">Website</a>}
        </p>
        {org.verified && <p class="org-verified">{org.verified}</p>}
      </div>
    </div>
  )}
  {people.map((p) => (
    <div class="person">
      {/* Raw <img> rather than <Placeholder src=...>, deliberately, even though Placeholder
          would carry these attributes for free: the grayscale rule below is a SCOPED style,
          and Astro scoped styles do not reach elements rendered by a child component. Route
          this through Placeholder and the portraits silently render in full colour. The FPO
          branch has no such rule, so it can stay a Placeholder.

          loading="lazy" because this block sits near the foot of a course page, far below
          the fold. Without it the two portraits were eager, and on a rate-limited r2.dev
          origin they were among the slowest requests on the page while contributing nothing
          to first paint. Aspect ratio is locked by .ph.r45 in global.css, so lazy-loading
          them costs no layout shift. */}
      {p.portrait
        ? <img class="ph r45" src={p.portrait.src} alt={p.portrait.alt} loading="lazy" decoding="async" />
        : <Placeholder ratio="r45" label="Portrait" desc={p.name} spec="4:5 · grayscale · FPO" />}
      <div>
        <h3 class="h3">{p.name}</h3>
        <p class="role">{p.role}</p>
        <ul class="cred-list" role="list">
          {credList(p.creds).map((c) => { const [a, b] = dualComma(c); return (
            <li>
              <span class="cl-a" set:html={a} />
              {b && <><span class="cl-sep" aria-hidden="true"> · </span><span class="cl-b" set:html={b} /></>}
            </li>
          ); })}
        </ul>
        {/* When there is a full profile to link to, this card is the SUMMARY of it, so it
            shows the opening paragraph and sends the reader on. Printing three paragraphs
            here and three more on the profile page makes the card long without making it
            more convincing, and buries the credential list that does the actual work. With
            no profile to link to, nothing else carries the bio, so all of it stays. */}
        {(p.profileHref ? p.bio.slice(0, 1) : p.bio).map((para) => <p set:html={para} />)}
        {/* ABE's own profile is the primary action: it is on this site, it carries the dated
            verification line, and it is the page the E-E-A-T story actually lives on.
            LinkedIn is corroboration, so it drops to secondary. */}
        <p class="p-links">
          {p.profileHref && <a class="pl" href={p.profileHref}>Full profile →</a>}
          <a class="pl pl-2" href={p.linkedin} rel="noopener">LinkedIn</a>
        </p>
      </div>
    </div>
  ))}
</div>
<style>
  /* Real portraits: crop to the frame and render grayscale to match the design register.
     For colour headshots instead, delete the `filter` line. */
  .person img.ph { object-fit: cover; filter: grayscale(100%); transition: filter .35s ease; }
  .person img.ph:hover { filter: grayscale(0); }
  /* RTO developer card: a monogram badge stands in for the portrait, in the same r45 frame so
     the org card lines up with the reviewer's person card. Uses the maroon accent, not a photo. */
  .org-badge {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: .25rem; background: var(--maroon, #800000); color: #fff; text-align: center;
  }
  .org-badge .rb-k { font: 600 .7rem/1 var(--font-mono, monospace); letter-spacing: .18em; opacity: .85; }
  .org-badge .rb-n { font: 700 1.6rem/1 var(--font-mono, monospace); }
  .org-verified { font-size: .8rem; color: var(--ink-3, #666); margin-top: .35rem; }
  /* Two-tone cred lines, two greys: the primary phrase carries the weight in dark grey, the trailing
     detail recedes in light grey, divided by a middot in the lightest grey. */
  .cred-list .cl-a { color: #3a3a3a; font-weight: 600; }
  .cred-list .cl-b { color: #8a8a8a; }
  .cred-list .cl-sep { color: #c4c4c4; }
</style>
