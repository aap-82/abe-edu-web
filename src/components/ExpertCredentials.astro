---
import { getEntries, getCollection } from 'astro:content';
import Credentials from './Credentials.astro';

// Resolves `experts` references into the people `Credentials` expects, so a course MDX
// body can keep rendering the "Developed and reviewed by" block without the expert data
// being copy-pasted into its frontmatter.
//
// This exists because course frontmatter now holds references, not inline objects, and
// an MDX body cannot resolve a collection reference itself. `Credentials` is deliberately
// left untouched — it still takes plain people and is still used directly elsewhere.
//
// The prop accepts BOTH shapes on purpose. Inside an MDX body, `frontmatter.experts` is
// the RAW parsed YAML (plain id strings) — Astro's Zod `reference()` transform applies to
// the collection entry's `data`, not to the `frontmatter` export. Anywhere holding real
// collection data (a layout, the styleguide) passes `{ collection, id }` objects instead.
// Normalising here means neither caller has to care.
type ExpertRef = string | { collection: 'experts'; id: string };
interface Props {
  experts: ExpertRef[];
  profileBase?: string;   // where each person's profile page lives
  // asqa-accredited only: the RTO number of the course developer. When set, the matching
  // `partners` record fills the developer slot with an organisation card, since no ABE Education person
  // develops an accredited course (kb/rules/authority-model.md §6). Silently ignored if no
  // partner record matches, so a non-asqa page passing nothing behaves exactly as before.
  developerRto?: string;
}
// Defaulted, not opt-in. Every expert in the collection has a rendered profile page at
// /experts/{id}, so there is no case where a course page should link a person's name to
// LinkedIn instead of to ABE Education's own dated, sourced profile of them. Leaving this optional
// meant all five course pages silently pointed off-site; making it a default fixes them
// all without touching five MDX files. Pass an explicit value to override.
const { experts, profileBase = '/experts', developerRto } = Astro.props;

const refs = experts.map((e) =>
  typeof e === 'string' ? { collection: 'experts' as const, id: e } : e,
);
const entries = await getEntries(refs);
const people = entries.map((e) => (
  profileBase ? { ...e.data, profileHref: `${profileBase}/${e.id}` } : e.data
));

// Resolve the RTO developer card from the partners collection by number. Matched here rather
// than referenced in frontmatter so `partnerRto.rtoNumber` stays the single RTO identity on the
// page and no course file has to carry a second reference to the same organisation.
const org = developerRto
  ? (await getCollection('partners')).find((p) => p.data.rtoNumber === developerRto)?.data
  : undefined;
---
<Credentials people={people} org={org} />
