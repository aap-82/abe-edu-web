---
import Placeholder from './Placeholder.astro';
import ProcessTrack from './ProcessTrack.astro';
import type { CTA } from '../types/course';
interface Proof { n: string; text: string; }
interface Props {
  eyebrow: string;
  h1Html: string;          // may include <span class="dot">.</span>
  updated: string;
  subhead: string;
  ticks: string[];         // 3-4
  cta: CTA;                // href, label, microcopy
  proof: Proof[];          // <=3, text only
  howItWorks: string;      // flow text after "How it works:"
  artefactDesc: string;
  artefactSpec?: string;
  artefactImg?: string;   // real image URL; omit to keep the FPO placeholder
  artefactAlt?: string;
}
const { eyebrow, h1Html, updated, subhead, ticks, cta, proof, howItWorks, artefactDesc, artefactSpec, artefactImg, artefactAlt } = Astro.props;

// Ticks carry inline markup: the lead phrase is bolded, the qualifier follows a comma.
// Emitted via set:html so <b> renders rather than printing as text.
const ticksHtml = ticks.map((t) => `<li>${t}</li>`).join('');

// The eyebrow's middot separator becomes a tinted bullet. split/join rather than a
// regex so the character is matched literally, and the span is hoisted into its own
// const so no template literal nests inside another's interpolation.
const dotSep = '<span class="e-dot">•</span>';
const eyebrowHtml = eyebrow.split(' · ').join(' ' + dotSep + ' ');
---
<section class="hero" id="top">
  <div class="wrap">
    <div>
      <span class="eyebrow" set:html={eyebrowHtml}></span>
      <h1 class="h1" set:html={h1Html} />
      <span class="updated">{updated}</span>
      <p class="lede">{subhead}</p>
      <ul class="hero-ticks" set:html={ticksHtml}></ul>
      <div class="hero-cta">
        <a class="btn-primary" href={cta.href} id="enrol">{cta.label}</a>
        <a class="btn-secondary" href="#how">How it works</a>
      </div>
      {cta.microcopy && <p class="howline" style="margin-top:12px">{cta.microcopy}</p>}
      {/* Dividers are drawn by CSS between stats, so a wrap can never strand one. */}
      <div class="proof">
        {proof.map((p) => (
          <span class="stat"><span class="n num">{p.n}</span> {p.text}</span>
        ))}
      </div>
      <ProcessTrack steps={howItWorks} />
    </div>
    <div class="z-img">
      <Placeholder ratio="r54" desc={artefactDesc} spec={artefactSpec} src={artefactImg} alt={artefactAlt} />
    </div>
  </div>
</section>
