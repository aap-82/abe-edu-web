---
// Hero "how it works" line: a PROCESS eyebrow over a numbered rail (variant A). Numbered
// steps joined by a thin connector that reads as "then"; the last number turns verify-blue
// to mark the hand-off to the regulator.
//
// The steps arrive as one " → "-separated string (the frontmatter howItWorks field), so
// this stays a single source of truth per page and the last step changes with it.
//
// The rail's layout is driven by a @container query, not a viewport breakpoint: the hero's
// left column carries container-type:inline-size, so it lays out against the width it
// actually has. Wide enough -> one line with growing connectors; too narrow -> the steps
// wrap and the connectors drop away. Font scales with the column.
interface Props { steps: string; label?: string; }
const { steps, label = 'Process' } = Astro.props;
const nodes = steps.split(' → ').map((s) => s.trim()).filter(Boolean);
---
<div class="howtrack">
  <span class="ht-eyebrow">{label}</span>
  <div class="ht-rail">
    {nodes.map((n, i) => (
      <>
        {i > 0 && <span class="ht-link" aria-hidden="true"></span>}
        <span class="ht-node"><span class="ht-n" aria-hidden="true">{i + 1}</span>{n}</span>
      </>
    ))}
  </div>
</div>
<style>
  .howtrack{ margin-top:var(--s-lg); display:flex; flex-direction:column; align-items:flex-start; gap:10px; }
  /* eyebrow: mono uppercase label above the rail */
  .ht-eyebrow{ display:inline-flex; align-items:center; font-family:var(--font-mono); font-size:10px; font-weight:500; letter-spacing:.16em; text-transform:uppercase; color:var(--slate); }

  /* the numbered rail: wrapped by default (mobile-first), connectors hidden */
  .ht-rail{ align-self:stretch; display:flex; flex-wrap:wrap; align-items:center; gap:9px 12px; font-family:var(--font-mono); font-size:11px; letter-spacing:.01em; color:var(--ink-2); }
  .ht-node{ flex:none; display:inline-flex; align-items:center; gap:7px; white-space:nowrap; }
  .ht-n{ display:inline-flex; align-items:center; justify-content:center; width:17px; height:17px; border-radius:50%; background:var(--maroon); color:#fff; font-size:10px; font-weight:500; flex:none; }
  /* the last step is the hand-off to the regulator: mark its number in the verify blue */
  .ht-node:last-child .ht-n{ background:var(--verify); }
  .ht-link{ display:none; }

  /* one line once the column can hold it (keyed to the column, not the viewport) */
  @container (min-width:560px){
    .ht-rail{ flex-wrap:nowrap; white-space:nowrap; gap:0; font-size:clamp(9.5px, 1.8cqw, 11px); }
    .ht-link{ display:block; flex:1 1 auto; min-width:14px; height:1px; margin:0 12px; background:var(--rule-strong); }
  }
</style>
