---
import Section from './Section.astro';
import ZSplit from './ZSplit.astro';
import BlockRenderer from './BlockRenderer.astro';
import SectionWayfinder from './SectionWayfinder.astro';
import type { SectionData } from '../content.config';

interface Props {
  section: SectionData;
  index: number; // 0-based
  total: number;
  next?: { label: string; href: string };
}
const { section: s, index, next } = Astro.props;

const marker = String(index + 1).padStart(2, '0');
const onDark = s.shell === 'dark' || s.bg === 'bg-dark';
---
{s.shell === 'zsplit' ? (
  <section class="sec" id={s.id}><div class="wrap">
    <ZSplit rev={s.rev} imgRatio={s.image!.ratio} imgDesc={s.image!.desc} imgSpec={s.image!.spec} imgSrc={s.image!.image?.src} imgAlt={s.image!.image?.alt}>
      <span class="eyebrow"><span class="eyebrow-i">{marker}</span>{s.eyebrow}</span>
      <h2 class="h2" set:html={s.h2} />
      {s.blocks.map((block) => <BlockRenderer block={block} />)}
    </ZSplit>
    {next && <SectionWayfinder label={next.label} href={next.href} />}
  </div></section>
) : (
  <Section
    id={s.id}
    bg={s.shell === 'dark' ? 'bg-dark' : s.bg}
    marker={marker}
    eyebrow={s.eyebrow}
    h2={s.h2}
  >
    {s.blocks.map((block) => <BlockRenderer block={block} />)}
    {next && <SectionWayfinder label={next.label} href={next.href} onDark={onDark} />}
  </Section>
)}
