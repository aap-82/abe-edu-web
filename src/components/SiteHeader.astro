---
// Top site navigation: a single row carrying the brand lockup, three megamenus, the
// secondary links, and the student sign-in.
//
// COMPILER NOTE: do not nest a template literal inside a ${...} interpolation of
// another template literal in this frontmatter. The Astro 7 Rust compiler mis-scans
// it and fails with a bogus "Expected } but found :" pointing at the first interface,
// nowhere near the real fault. Hoist the inner literal into its own const, the way
// priceHtml, trigger and mGroup do below.
//
// Sticky behaviour: one row, position sticky at top 0, a constant 66px tall. That is
// what --head-h in global.css assumes, so the wayfinder sub-nav offset and the section
// scroll-margins keep working without touching that shared file.
//
// The second word of the wordmark, Education, folds away once you scroll past the
// sentinel, leaving the square mark plus ABE. The logo asset is a square mark with no
// baked-in text, so the wordmark is real text and can fold.
//
// Nav markup is emitted via set:html because this compiler mis-parses dynamic
// attributes inside mapped ternary JSX. Its CSS is an is:global block scoped under
// .site-head because scoped styles do not reach set:html content. Do not simplify it
// back to inline JSX. Sticky and layout rules use header.site-head as the selector so
// they beat global.css whatever the stylesheet order.

const logo = 'https://pub-e001e9a575874f24a0bcd7082a45cdbc.r2.dev/ABE%20Education%20Online%20Owner%20Builder%20CPD%20Training%20Provider.svg';

interface Sub { code: string; name: string; href?: string; soon?: boolean; desc: string; }
interface Feature { kicker: string; title: string; body: string; price?: string; }
interface Hub { label: string; href: string; }
interface Group { label: string; megaLabel: string; hub: Hub; items: Sub[]; feature: Feature; }
interface Link { label: string; href: string; }
// CPD nests three levels: state, then profession, then the bundles themselves. A
// profession can carry more than one bundle, so the bundle is the link and the
// profession is only a label.
interface CpdBundle { label: string; href?: string; soon?: boolean; }
interface CpdProfession { name: string; bundles: CpdBundle[]; }
interface CpdState { code: string; professions: CpdProfession[]; }
interface CpdGroup { label: string; megaLabel: string; hub: Hub; states: CpdState[]; feature: Feature; }

// Authority lines are legally load-bearing. QLD is QBCC-approved; WA only supports a
// Form 75 approval, since no approved owner-builder course exists in WA; NSW and the
// White Card are nationally recognised via the RTO partner. Unreleased states claim
// nothing at all.
const courses: Group[] = [
  {
    label: 'Owner Builder',
    megaLabel: 'Owner builder courses by state',
    hub: { label: 'Owner Builder Hub', href: 'https://www.abeeducation.edu.au/owner-builder-courses' },
    items: [
      // Inert until the NSW page is rebuilt here. It still exists on the old apex, but
      // the menu links to Astro routes only, so this renders as a label, not a link.
      { code: 'NSW', name: 'NSW Owner Builder', soon: true, desc: 'Nationally recognised, with our RTO partner' },
      { code: 'QLD', name: 'QLD Owner Builder', href: '/qld-owner-builder-course', desc: 'Approved by the QBCC' },
      { code: 'WA', name: 'WA Owner Builder', href: '/wa-owner-builder-course', desc: 'Supports your Form 75 approval' },
      { code: 'TAS', name: 'TAS Owner Builder', soon: true, desc: 'In development' },
      { code: 'ACT', name: 'ACT Owner Builder', soon: true, desc: 'In development' },
    ],
    feature: { kicker: 'Most popular', title: 'WA Owner Builder', body: 'Written for WA and reviewed for currency. Same-day certificate, ready for your Form 75.', price: '$179' },
  },
  {
    label: 'White Card',
    megaLabel: 'White Card by state',
    hub: { label: 'White Card Hub', href: 'https://www.abeeducation.edu.au/white-card' },
    items: [
      // TODO: /white-card-nsw 404s on the apex, as do five other slug variants I
      // probed. Flagged soon so it renders inert rather than linking to a 404.
      // Restore the href the moment the real URL is known.
      { code: 'NSW', name: 'White Card NSW', soon: true, desc: 'Nationally recognised construction induction' },
      { code: 'QLD', name: 'White Card QLD', soon: true, desc: 'In development' },
      { code: 'WA', name: 'White Card WA', soon: true, desc: 'In development' },
    ],
    feature: { kicker: 'Delivered with', title: 'Blue Dog Training', body: 'Nationally recognised training, delivered with our RTO partner Blue Dog Training (RTO 31193).' },
  },
];

// CPD sits in the primary row between the two course families, and opens its own
// megamenu. Unlike the course families, which key off state alone, CPD is grouped
// state first, then profession, because point requirements and cycles are set per
// profession by each state regulator.
//
// TODO: no bundle has a page yet, on this site or the old one, so each is flagged
// soon and renders as an inert label rather than a link to a 404. Give a bundle its
// href and drop the soon flag to turn it back into a link. The bundles below are the
// examples supplied, not a full catalogue.
const cpd: CpdGroup = {
  label: 'CPD',
  megaLabel: 'CPD bundles by state and profession',
  hub: { label: 'CPD Hub', href: '/cpd' },
  states: [
    { code: 'NSW', professions: [
      { name: 'Building', bundles: [
        { label: '36 Points CPD Bundle 2026', soon: true },
      ] },
    ] },
    { code: 'TAS', professions: [
      { name: 'Building', bundles: [
        { label: '12 Points CPD Bundle 2026', soon: true },
        { label: '9 Points CPD Bundle 2026', soon: true },
      ] },
      { name: 'Plumbing', bundles: [
        { label: '12 Points CPD Bundle 2026', soon: true },
      ] },
    ] },
    { code: 'WA', professions: [
      { name: 'Real Estate', bundles: [
        { label: '5 Points Bundle 2026', soon: true },
      ] },
    ] },
  ],
  // No authority claim here: points and cycles are the regulator's, not ABE's.
  feature: { kicker: 'Points and cycles', title: 'Set by your regulator', body: 'How many points you need, and when your cycle resets, differs by state and profession. Check with your regulator before you buy.' },
};

const utility: Link[] = [
  { label: 'Experts', href: '#content-review' },
  { label: 'Insurance', href: 'https://www.abeeducation.edu.au/insurances' },
];

// Student sign-in, in the main row where the enrol CTA used to sit. Outlined rather
// than filled: it is a returning-student action, not the page's primary conversion,
// so it should not carry the visual weight of a solid button.
// TODO: href is a placeholder pending the real LearnWorlds portal URL (the rebuild
// plan moves LearnWorlds to a learn. subdomain).
const studentPortal: Link = { label: 'Student Portal', href: '#' };

const norm = (h?: string) => (h ?? '').replace(/\/+$/, '') || '/';
const path = norm(Astro.url.pathname);
const on = (h?: string) => !!h && h.startsWith('/') && norm(h) === path;
const groupOn = (g: Group) => g.items.some((s) => !s.soon && on(s.href));

const card = (s: Sub) => s.soon
  ? `<span class="mcard soon"><span class="mst">${s.code}</span><span class="mname">${s.name}<em>Soon</em></span><span class="mdesc">${s.desc}</span></span>`
  : `<a class="mcard${on(s.href) ? ' active' : ''}" href="${s.href}"${on(s.href) ? ' aria-current="page"' : ''}><span class="mst">${s.code}</span><span class="mname">${s.name}</span><span class="mdesc">${s.desc}</span></a>`;

const priceHtml = (f: Feature) => f.price ? `<span class="mfeat-p">${f.price}</span>` : '';

const mega = (g: Group, i: number) => `<div class="mega" id="mega-${i}">`
  + `<div class="mega-in">`
  + `<div class="mcol"><p class="mlabel">${g.megaLabel}</p><div class="mgrid">${g.items.map(card).join('')}</div></div>`
  + `<div class="mcol mcol-side"><p class="mlabel">Start here</p>`
  + `<a class="mlink" href="${g.hub.href}">${g.hub.label} <span class="arr" aria-hidden="true">&rarr;</span></a>`
  + `<div class="mfeat"><span class="mfeat-k">${g.feature.kicker}</span><p class="mfeat-t">${g.feature.title}</p><p class="mfeat-d">${g.feature.body}</p>`
  + priceHtml(g.feature)
  + `</div></div></div></div>`;

// CPD panel: a column per state, each profession a label above its bundle links.
const cpdOn = cpd.states.some((s) => s.professions.some((p) => p.bundles.some((b) => !b.soon && on(b.href))));

const cpdBundle = (b: CpdBundle) => b.soon
  ? `<span class="cbundle soon">${b.label}<em>Soon</em></span>`
  : `<a class="cbundle${on(b.href) ? ' active' : ''}" href="${b.href}"${on(b.href) ? ' aria-current="page"' : ''}>${b.label}</a>`;

const cpdProf = (p: CpdProfession) => `<div class="cprof-group"><p class="cprof">${p.name}</p>`
  + p.bundles.map(cpdBundle).join('')
  + `</div>`;

const cpdCol = (s: CpdState) => `<div class="cstate"><span class="cst">${s.code}</span>`
  + s.professions.map(cpdProf).join('')
  + `</div>`;

const cpdMega = (g: CpdGroup, i: number) => `<div class="mega" id="mega-${i}">`
  + `<div class="mega-in">`
  + `<div class="mcol"><p class="mlabel">${g.megaLabel}</p><div class="cgrid">`
  + g.states.map(cpdCol).join('')
  + `</div></div>`
  + `<div class="mcol mcol-side"><p class="mlabel">Start here</p>`
  + `<a class="mlink" href="${g.hub.href}">${g.hub.label} <span class="arr" aria-hidden="true">&rarr;</span></a>`
  + `<div class="mfeat"><span class="mfeat-k">${g.feature.kicker}</span><p class="mfeat-t">${g.feature.title}</p><p class="mfeat-d">${g.feature.body}</p>`
  + priceHtml(g.feature)
  + `</div></div></div></div>`;

// Chevron: stroke is currentColor so it inherits the trigger colour and turns maroon
// on hover and while open. Decorative, hence aria-hidden and focusable=false.
//
// The source icon draws its chevron from x 9.5 to 15.5 inside a 0 0 24 24 canvas, so
// the glyph fills only a quarter of the box. Sizing the box alone leaves dead space
// beside the label. Instead the viewBox is cropped to the stroke-inclusive bounds
// (8.5 9.5 8 5) and the box is 13x8, giving a 9.6px chevron. Stroke width scales with
// the viewBox: at this crop 1.0 renders as about 1.6px. Path coordinates untouched.
const chevron = `<svg class="cv" viewBox="8.5 9.5 8 5" fill="none" aria-hidden="true" focusable="false"><path d="M9.5 10.5L12.1997 13.1997V13.1997C12.3656 13.3656 12.6344 13.3656 12.8003 13.1997V13.1997L15.5 10.5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

// Disclosure pattern (button + aria-expanded + aria-controls), not an ARIA menu:
// the panels hold links, so role menu and menuitem would be the wrong semantics.
const triggerFor = (label: string, active: boolean, i: number) => `<button type="button" class="nav-trigger${active ? ' active' : ''}" aria-expanded="false" aria-controls="mega-${i}">${label}${chevron}</button>`;

const megaItem = (g: Group, i: number) => `<div class="ni ni-mega">` + triggerFor(g.label, groupOn(g), i) + mega(g, i) + `</div>`;
const cpdItem = (g: CpdGroup, i: number) => `<div class="ni ni-mega">` + triggerFor(g.label, cpdOn, i) + cpdMega(g, i) + `</div>`;

// Experts and Insurance have no panel behind them, so they render as plain links.
const navLink = (l: Link) => `<a class="nav-l${on(l.href) ? ' active' : ''}" href="${l.href}">${l.label}</a>`;

// One row: the three panels first, then the secondary links.
const navHtml = megaItem(courses[0], 0) + cpdItem(cpd, 1) + megaItem(courses[1], 2)
  + utility.map(navLink).join('');

const link = (l: Link) => `<a href="${l.href}">${l.label}</a>`;

// Burger menu keeps everything the strip drops on small screens.
const moreLinks = utility.concat([studentPortal]).map(link).join('');

const mSub = (s: Sub) => s.soon
  ? `<span class="dd-soon" aria-disabled="true">${s.name}<em>Soon</em></span>`
  : `<a href="${s.href}"${on(s.href) ? ' class="active" aria-current="page"' : ''}>${s.name}</a>`;

const mGroup = (g: Group) => `<div class="bg"><p class="bg-h">${g.label}</p>`
  + g.items.map(mSub).join('')
  + `<a class="bg-hub" href="${g.hub.href}">${g.hub.label}</a></div>`;

// Mobile CPD: a "STATE PROFESSION" sub-label, then that profession's bundle links.
const mCpdBundle = (b: CpdBundle) => b.soon
  ? `<span class="dd-soon" aria-disabled="true">${b.label}<em>Soon</em></span>`
  : `<a href="${b.href}">${b.label}</a>`;
const mCpdProf = (code: string, p: CpdProfession) => `<p class="bg-sub">${code} ${p.name}</p>`
  + p.bundles.map(mCpdBundle).join('');
const mCpdCol = (s: CpdState) => s.professions.map((p) => mCpdProf(s.code, p)).join('');
const mCpdGroup = `<div class="bg"><p class="bg-h">CPD</p>`
  + cpd.states.map(mCpdCol).join('')
  + `<a class="bg-hub" href="${cpd.hub.href}">${cpd.hub.label}</a></div>`;

// Burger order mirrors the primary row: Owner Builder, CPD, White Card, then More.
const mnavHtml = mGroup(courses[0]) + mCpdGroup + mGroup(courses[1])
  + `<div class="bg"><p class="bg-h">More</p>` + moreLinks + `</div>`;
---
<div id="head-sentinel" aria-hidden="true"></div>
<header class="site-head">
  <div class="main">
    <div class="wrap">
      <a class="brand" href="/" aria-label="ABE Education home">
        <img class="mark" src={logo} alt="" width="32" height="32" />
        <span class="wordmark">ABE<span class="wm-fold">&nbsp;Education</span></span>
      </a>
      <nav class="head-nav" aria-label="Primary" set:html={navHtml}></nav>
      <span class="spacer"></span>
      <a class="portal-btn" href={studentPortal.href}>{studentPortal.label}</a>
      <button type="button" class="burger-btn" aria-expanded="false" aria-controls="mnav" aria-label="Menu">
        <span class="bars" aria-hidden="true"></span>
      </button>
    </div>
  </div>
  <div id="mnav" class="mnav" set:html={mnavHtml}></div>
</header>
<script>
  const head = document.querySelector('.site-head');
  if (head) {
    /* megamenu: click to open, hover only tints */
    const items = Array.from(head.querySelectorAll('.ni'));
    const shut = (except) => items.forEach((i) => {
      if (i !== except) { i.classList.remove('open'); i.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false'); }
    });
    items.forEach((i) => {
      const btn = i.querySelector('.nav-trigger');
      btn?.addEventListener('click', () => {
        const open = !i.classList.contains('open');
        shut(open ? i : null);
        i.classList.toggle('open', open);
        btn.setAttribute('aria-expanded', String(open));
      });
    });
    head.querySelectorAll('.mega a').forEach((a) => a.addEventListener('click', () => shut(null)));

    /* mobile menu */
    const bBtn = head.querySelector('.burger-btn');
    const mnav = head.querySelector('#mnav');
    const shutM = () => { mnav?.classList.remove('open'); bBtn?.setAttribute('aria-expanded', 'false'); };
    bBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = !mnav.classList.contains('open');
      mnav.classList.toggle('open', open);
      bBtn.setAttribute('aria-expanded', String(open));
    });
    mnav?.querySelectorAll('a').forEach((a) => a.addEventListener('click', shutM));

    document.addEventListener('click', (e) => { if (!head.contains(e.target)) { shut(null); shutM(); } });
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const open = items.find((i) => i.classList.contains('open'));
      if (open) { const btn = open.querySelector('.nav-trigger'); shut(null); btn?.focus(); }
      shutM();
    });

    /* scroll-folding wordmark: one class flip, no scroll handler */
    const sentinel = document.getElementById('head-sentinel');
    if (sentinel && 'IntersectionObserver' in window) {
      new IntersectionObserver(
        ([e]) => head.classList.toggle('is-scrolled', !e.isIntersecting),
        { threshold: 0 },
      ).observe(sentinel);
    }
  }
</script>
<style is:global>
  /* sentinel: out of flow, 24px down the page. Fold fires when it leaves the viewport. */
  #head-sentinel{ position:absolute; top:24px; left:0; width:1px; height:1px; pointer-events:none; }

  /* element+class specificity so these beat global.css whatever the sheet order */
  /* --active-bg: light grey for the current page. Only a whisper of warmth (red one
     point over blue); more tint than this reads pink beside the maroon title. Still
     a shade darker than the cream hover so active stays the stronger state. */
  /* The header sits on warm cream so it reads as chrome, clearly distinct from the
     white hero beneath it. That means the old hover tint (#f6f3ee) is now the same
     colour as the bar itself and would be invisible, so hovers use a maroon wash. */
  header.site-head{ --active-bg:#f1f0f0; --nav-hover:rgba(128,0,0,.06); position:sticky; top:0; z-index:50; background:var(--paper-warm); border-bottom:1px solid var(--rule); }

  /* the one row: 66px, matching --head-h in global.css */
  .site-head .main .wrap{ height:66px; padding:0 28px; display:flex; align-items:center; gap:18px; }
  .site-head .spacer{ flex:1; }

  /* brand lockup + folding wordmark */
  .site-head .brand{ display:inline-flex; align-items:center; gap:10px; text-decoration:none; color:var(--ink); flex:none; }
  .site-head .mark{ height:32px; width:32px; display:block; flex:none; }
  .site-head .wordmark{ font-family:var(--font-display); font-weight:600; font-size:18px; letter-spacing:-.02em; color:var(--ink); white-space:nowrap; display:inline-flex; align-items:center; }
  /* clip-path, not max-width. max-width is a layout property: animating it narrows the
     brand, and every flex sibling after it (the whole nav) slides left with it. The nav
     must hold its left edge, so the fold gives up reclaiming the space and only stops
     painting it. inset() eats the letters from the right edge inward, exactly as the
     shrinking max-width box used to, and costs no layout or paint on the main thread.
     Scoped to one inline span, fired once per threshold crossing, not per scroll frame.

     Unfolding is the fold played backwards, not a second animation that happens to end
     where the first began. Rewinding a transition means two things:
       easing  - the reverse of a curve (x1,y1,x2,y2) is (1-x2,1-y2,1-x1,1-y1). Applied
                 to ease-out-expo (.16,1,.3,1) that gives ease-in-expo (.7,0,.84,0). The
                 fold leaves fast and lands soft; the unfold creeps then springs open.
       delay   - the fade occupies the FIRST 320ms of the 900ms fold, so it must occupy
                 the LAST 320ms of the unfold: delay 900-320 = 580ms.
     The transition on the base rule governs the way back, so ease-in-expo lives here.
     Same 900ms, same distance, opposite direction. */
  .site-head .wm-fold{ display:inline-block; white-space:nowrap; clip-path:inset(0 0 0 0); opacity:1; transform:translateX(0); transition:clip-path 900ms cubic-bezier(.7,0,.84,0), opacity 320ms linear 580ms, transform 900ms cubic-bezier(.7,0,.84,0); will-change:clip-path, opacity, transform; }
  .site-head.is-scrolled .wm-fold{ clip-path:inset(0 100% 0 0); opacity:0; transform:translateX(-6px); transition:clip-path 900ms cubic-bezier(.16,1,.3,1), opacity 320ms linear, transform 900ms cubic-bezier(.16,1,.3,1); }

  /* primary nav triggers */
  .site-head .head-nav{ display:flex; align-items:center; gap:2px; margin-left:8px; }
  .site-head .nav-trigger{ font-family:var(--font-mono); font-size:12.5px; letter-spacing:.06em; text-transform:uppercase; font-weight:500; color:var(--ink-3); background:none; border:0; cursor:pointer; line-height:1; display:inline-flex; align-items:center; gap:6px; padding:10px 12px; border-radius:7px; transition:color .15s, background .15s; }
  .site-head .nav-trigger:hover{ color:var(--maroon); background:var(--nav-hover); }
  .site-head .nav-trigger.active{ color:var(--maroon); }
  .site-head .ni.open .nav-trigger{ color:var(--maroon); background:var(--nav-hover); }
  /* Experts and Insurance: plain links, no chevron, since no panel sits behind them */
  .site-head .nav-l{ font-family:var(--font-mono); font-size:12.5px; letter-spacing:.06em; text-transform:uppercase; font-weight:500; color:var(--ink-3); text-decoration:none; line-height:1; display:inline-flex; align-items:center; padding:10px 12px; border-radius:7px; transition:color .15s, background .15s; }
  .site-head .nav-l:hover{ color:var(--maroon); background:var(--nav-hover); }
  .site-head .nav-l.active{ color:var(--maroon); }
  /* chevron is an svg: sized in px, coloured via currentColor on the path.
     Box is 13x8 to match the cropped viewBox's 8:5 ratio, so there is no dead space. */
  .site-head .cv{ width:13px; height:8px; flex:none; color:var(--slate-light); transition:transform .18s, color .15s; }
  .site-head .nav-trigger:hover .cv, .site-head .ni.open .cv{ color:var(--maroon); }
  .site-head .ni.open .cv{ transform:rotate(180deg); }
  .site-head .nav-trigger:focus-visible,
  .site-head .nav-l:focus-visible,
  .site-head .burger-btn:focus-visible,
  .site-head .portal-btn:focus-visible,
  .site-head .mega a:focus-visible{ outline:2px solid var(--maroon); outline-offset:2px; }

  /* student sign-in: outlined, not filled. It is a returning-student action, so it
     borrows the ghost-button language from global.css rather than the solid CTA. */
  .site-head .portal-btn{ flex:none; background:transparent; color:var(--ink); border:1px solid var(--rule-strong); font-family:var(--font-body); font-weight:600; font-size:14.5px; padding:9px 17px; border-radius:7px; text-decoration:none; white-space:nowrap; transition:color .15s, border-color .15s; }
  .site-head .portal-btn:hover{ color:var(--maroon); border-color:var(--ink); }

  /* megamenu */
  .site-head .ni{ position:relative; }
  .site-head .ni-mega{ position:static; }
  .site-head .mega{ position:absolute; left:0; right:0; top:100%; background:var(--paper); border-bottom:1px solid var(--rule-strong); box-shadow:0 18px 36px rgba(0,0,0,.09); opacity:0; visibility:hidden; transform:translateY(-6px); pointer-events:none; transition:opacity .18s ease, transform .18s ease, visibility .18s; z-index:70; }
  .site-head .ni.open > .mega{ opacity:1; visibility:visible; transform:none; pointer-events:auto; }
  /* click-only by design: there is deliberately no .ni:hover > .mega rule */
  .site-head .mega-in{ max-width:var(--max); margin:0 auto; display:grid; grid-template-columns:1.9fr 1fr; gap:38px; padding:26px 28px 30px; }
  .site-head .mlabel{ font-family:var(--font-mono); font-size:10px; letter-spacing:.16em; text-transform:uppercase; color:var(--slate); margin-bottom:14px; }
  .site-head .mgrid{ display:grid; grid-template-columns:1fr 1fr; gap:2px 16px; }
  .site-head .mcard{ display:grid; grid-template-columns:46px 1fr; gap:0 14px; align-items:start; padding:11px 12px; border-radius:8px; text-decoration:none; transition:background .15s; }
  .site-head a.mcard:hover{ background:#f6f3ee; }
  .site-head .mst{ grid-row:span 2; align-self:center; font-family:var(--font-mono); font-size:12px; font-weight:500; color:var(--maroon); border:1px solid var(--rule-strong); border-radius:6px; padding:7px 0; text-align:center; }
  .site-head .mname{ font-family:var(--font-body); font-weight:600; font-size:14.5px; color:var(--ink); display:flex; align-items:center; gap:8px; }
  .site-head .mdesc{ font-size:12.5px; color:var(--slate); line-height:1.45; margin-top:3px; }
  .site-head .mcard.active{ background:var(--active-bg); }
  .site-head .mcard.active .mname{ color:var(--maroon); }
  /* slate would fall to 4.39:1 on the grey; ink-3 keeps this 12.5px line above AA */
