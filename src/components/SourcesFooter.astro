---
import type { Source } from '../types/course';
// Global site footer (W0-4). The link columns, the three-line publisher/RTO/enrolment
// block and the sitewide ASQA disclosure are the same on every page, so they are
// hardcoded here rather than threaded through every layout's props, the same way
// SiteHeader hardcodes its own nav data. `sources` / `disclaimersHtml` stay page-specific
// props: they are this page's own sourced facts, not sitewide chrome.
//
// Footer links may point at routes that do not exist yet - they land across Waves 1-5.
// That is expected on the preview; do not add a link here for a route with no ticket.
// `asqa` gates the RTO-partner content. On a page that is NOT asqa-accredited (state-approved-direct,
// knowledge-requirement, a hub, a static page) naming three RTO partners is irrelevant at best and at
// worst implies an RTO is involved in a course that has none — the exact inference the
// knowledge-requirement model must not invite. So the partner list and the "ASQA-accredited training
// is delivered by the named RTO partner" sentence render only when the page actually is one.
//
// What does NOT move: "ABE Education is not a Registered Training Organisation" stays on EVERY page.
// It is a standing claim (CLAUDE.md), and three pages — cpd-building-tas, the owner-builder hub and
// reviews — carry it nowhere else, so gating it would delete it from them entirely.
interface Props { sources: Source[]; abn?: string; updated?: string; disclaimersHtml: string; asqa?: boolean; }
const { sources, abn = '64 125 455 272', updated = 'July 2026', disclaimersHtml, asqa = false } = Astro.props;

interface FLink { label: string; href: string; }
const coursesLinks: FLink[] = [
  { label: 'Owner Builder', href: '/owner-builder-courses' },
  { label: 'White Card', href: '/white-card' },
  { label: 'CPD Courses', href: '/cpd' },
  { label: 'CPD Bundles', href: '/cpd-bundles' },
];
const trustLinks: FLink[] = [
  { label: 'Accreditation', href: '/accreditation' },
  { label: 'Our experts', href: '/experts' },
  { label: 'Reviews', href: '/reviews' },
];
const companyLinks: FLink[] = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'FAQ', href: '/faq' },
];
const partnerLinks: FLink[] = [{ label: 'SA Australia', href: '/saaustralia' }];
const legalLinks: FLink[] = [
  { label: 'Terms', href: '/terms' },
  { label: 'Privacy', href: '/privacy' },
  { label: 'Cookies', href: '/cookies' },
  { label: 'Cancellation & refund policy', href: '/cancellation-and-refund-policy' },
];
---
<footer>
  <div class="wrap">
    {sources.length > 0 && (
      <div class="f-sources">
        <span class="f-col-h">Sources</span>
        <ul class="srclist">
          {sources.map((s) => (
            <li><a href={s.href}>{s.label}</a> {s.verified && <span class="vd">{s.verified}</span>}</li>
          ))}
        </ul>
      </div>
    )}
    <div class="f-links">
      <div class="f-col">
        <span class="f-col-h">Courses</span>
        <ul>{coursesLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </div>
      <div class="f-col">
        <span class="f-col-h">Trust</span>
        <ul>{trustLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </div>
      <div class="f-col">
        <span class="f-col-h">Company</span>
        <ul>{companyLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
        <span class="f-col-h f-col-sub">Partners</span>
        <ul>{partnerLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </div>
      <div class="f-col">
        <span class="f-col-h">Legal</span>
        <ul>{legalLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}</ul>
      </div>
    </div>

    <div class="f-pub">
      <p><b>Course publisher:</b> ABE Education.</p>
      {asqa && <p><b>Training providers:</b> Blue Dog Training (RTO 31193) · Upskill Institute (RTO 45708) · AlertForce (RTO 91826).</p>}
      {asqa
        ? <p><b>Enrolment:</b> processed through ABE Education; the nationally recognised training on this page is delivered and assessed by the named RTO partner.</p>
        : <p><b>Enrolment:</b> processed directly by ABE Education.</p>}
    </div>
    {asqa
      ? <p class="f-asqa">ABE Education is not a Registered Training Organisation (RTO). Nationally recognised, ASQA-accredited training on this site is delivered and assessed by the named RTO partner shown on that course page, not by ABE Education.</p>
      : <p class="f-asqa">ABE Education is not a Registered Training Organisation (RTO). Its owner builder and CPD courses are delivered directly by ABE Education under state government approvals.</p>}

    <div class="f-top">
      <a class="brand" href="#top"><span class="mk" aria-hidden="true">ABE</span><span class="wm">ABE Education</span></a>
      <span class="f-meta">ABN {abn} · Training Australians since 2007</span>
      <span class="f-meta">Last updated {updated}</span>
    </div>
    <p class="f-auth" set:html={disclaimersHtml} />
  </div>
</footer>
