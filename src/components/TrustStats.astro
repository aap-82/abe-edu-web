---
// Four-up stat cells on the dark trust band. `numeric` switches on the tabular
// numeral treatment (.num); leave it off for a word like "QBCC" or "WA".
export interface TrustStat { value: string; label: string; numeric?: boolean; }
interface Props { items: TrustStat[]; }
const { items } = Astro.props;
---
<div class="trust-stats">
  {items.map((s) => (
    <div class="tstat">
      <span class={s.numeric ? 'n num' : 'n'}>{s.value}</span>
      <span class="l">{s.label}</span>
    </div>
  ))}
</div>
