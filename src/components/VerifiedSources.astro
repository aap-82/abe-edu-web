---
import type { Source } from '../types/course';
// Verification ledger for any section carrying a government fact. Two columns:
//   Verified 24 Jun 2026 | Deposit caps fact-checked against the current Act
//                          against QBCC Act 1991, Schedule 1B
// The date sits on the left; the fact and its linked source(s) on the right, joined by
// "against". Always visible, source links crawlable for E-E-A-T. No JavaScript.
interface Props { date: string; facts?: string; sources: Source[]; }
const { date, facts, sources } = Astro.props;
const hasSources = sources.length > 0;
---
<div class="verified">
  <span class="v-date">
    <span class="v-label">
      <svg class="check" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M1.5 6.2 4.4 9 10.5 2.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      Verified
    </span>
    <span class="v-day">{date}</span>
  </span>
  <span class="v-body">
    {facts}{facts && hasSources && <span class="v-against"> against </span>}
    {sources.map((s, i) => (
      <>{i > 0 && ', '}{s.href ? <a href={s.href}>{s.label}</a> : s.label}</>
    ))}
  </span>
</div>
