---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import PageBar from '../components/PageBar.astro';
import StickyCta from '../components/StickyCta.astro';
import type { CTA, Crumb, Reviewed } from '../types/course';

interface Props {
  title: string;
  description: string;
  canonical: string;
  schema: unknown;               // JSON-LD @graph object, server-rendered
  sticky: { label: string; sub?: string; price: string; cta: CTA };
  authority?: string;            // authority model, exposed to the build-time guardrails
  ogImage?: string;              // absolute URL of a social share image; omit to ship text-only cards
  crumbs?: Crumb[];              // same source as the JSON-LD BreadcrumbList
  reviewed?: Reviewed;           // Warwick Smith on course pages, Dominic Ogburn on hubs
}
// WayfinderNav is not rendered here. It belongs between the hero and the first section,
// so each page places it itself. The scroll-spy script below finds it wherever it sits.
const { title, description, canonical, schema, sticky, authority, ogImage, crumbs, reviewed } = Astro.props;
---
<!doctype html>
<html lang="en-AU" data-authority={authority}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index,follow" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="ABE Education" />
  <meta property="og:locale" content="en_AU" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {/* Non-render-blocking font load (the W0-6 Lighthouse gate asserts zero render-blocking
      third-party requests). A plain <link rel="stylesheet"> to Google Fonts blocks first
      paint on a third-party origin; loading it as a print stylesheet that swaps to `all`
      once fetched keeps the exact same fonts and the existing display=swap fallback, just
      off the critical rendering path. The <noscript> keeps the fonts synchronous with JS
      disabled, so nothing regresses for that case.

      SELF-HOSTING WAS TRIED AND REVERTED (19-20 Jul 2026). Migration plan v2 §6.2 asks for
      self-hosted subset woff2, and on paper it is the better answer: no third-party origin,
      no extra DNS or TLS, no privacy surface. Measured on a course page, three runs each,
      dev server stopped:

        Google Fonts (this)                  FCP ~1000ms   LCP 1506ms   score 1.00
        self-hosted, 102KB                   FCP ~1815ms   LCP 2258ms   score 0.97
        self-hosted, subset to 93KB          FCP ~1663ms   LCP 2259ms   score 0.98
        self-hosted, @font-face off crit path              LCP 2260ms
        self-hosted + preload Archivo                      LCP 3009ms

      LCP is pinned near 2258ms no matter what is done to the bytes, which is a latency
      bound, not a bandwidth one. The LCP element is the <h1>, set in Archivo. Self-hosted,
      the face is reached via HTML -> CSS -> font: three sequential round trips at Lantern's
      simulated 562.5ms RTT, and the h1 repaints on swap at the end of them. Loaded this way
      the faces sit on a separate origin behind a non-blocking stylesheet, so they never
      enter that chain at all.

      Before re-attempting: the 750ms is substantially a Lighthouse simulation artifact
      (Lantern models bandwidth per origin), so self-hosting may well be faster for real
      users while measuring worse here. Reverted because the CI gate is the thing that
      blocks merges. If you revisit it, measure LCP before and after on a throttled run and
      do not assume preloading helps - it measured worst of everything tried. */}
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700&family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700&family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" /></noscript>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</head>
<body>
  <SiteHeader />
  {crumbs && <PageBar crumbs={crumbs} reviewed={reviewed} />}
  <slot />
  <StickyCta label={sticky.label} sub={sticky.sub} price={sticky.price} cta={sticky.cta} />

  <script>
    // Mobile CTA strip: reveal after the hero scrolls out of view.
    const strip = document.getElementById('ctastrip');
    const hero = document.getElementById('top');
    if (strip && hero && 'IntersectionObserver' in window) {
      new IntersectionObserver((es) => es.forEach((e) => {
        const show = !e.isIntersecting;
        strip.classList.toggle('show', show);
        strip.setAttribute('aria-hidden', show ? 'false' : 'true');
      }), { threshold: 0 }).observe(hero);
    } else if (strip) { strip.classList.add('show'); strip.setAttribute('aria-hidden', 'false'); }

    // Wayfinder: highlight the active section in the sticky sub-nav.
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.waynav a.j'));
    if (links.length && 'IntersectionObserver' in window) {
      const map = new Map(links.map((l) => [l.getAttribute('data-sec'), l]));
      const secs = links.map((l) => document.getElementById(l.getAttribute('data-sec') || '')).filter(Boolean) as HTMLElement[];
      const obs = new IntersectionObserver((es) => es.forEach((e) => {
        if (e.isIntersecting) {
          links.forEach((l) => l.classList.remove('active'));
          map.get(e.target.id)?.classList.add('active');
        }
      }), { rootMargin: '-45% 0px -50% 0px', threshold: 0 });
      secs.forEach((s) => obs.observe(s));
    }
  </script>
</body>
</html>
