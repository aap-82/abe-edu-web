---
import BaseLayout from './BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WayfinderNav from '../components/WayfinderNav.astro';
import CtaBand from '../components/CtaBand.astro';
import Section from '../components/Section.astro';
import PartnerDisclosure from '../components/PartnerDisclosure.astro';
import FactGrid from '../components/FactGrid.astro';
import CpdMatrix from '../components/CpdMatrix.astro';
import BundleOffer from '../components/BundleOffer.astro';
import SourcesFooter from '../components/SourcesFooter.astro';
import { getEntries } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props { course: CollectionEntry<'courses'>['data']; }
const { course } = Astro.props;
const {
  title, description, canonical, ogImage,
  nav, cta, sticky, hero, ctaBand, footerSources, disclaimersHtml,
  courseName, courseDescription, priceNumber, courseWorkload,
  credentialName, credentialCategory, regulator, breadcrumb, reviewedBy, experts,
  authorityModel, partnerRto, cpd,
} = course;

// `experts` are typed references into the `experts` collection, so resolve them before
// building the Person nodes. Same pattern HubLayout uses for its course spokes.
const expertEntries = await getEntries(experts);
const expertData = expertEntries.map((e) => e.data);

// CPD branch. The points-by-licence fact block reuses FactGrid (4 facts, matching its
// grid); the approval reference is a real government listing, so it links out rather
// than sitting inert inside the grid. matrix and bundle are each optional: not every
// CPD course needs a cross-state comparison or an upsell.
const cpdFacts = cpd ? [
  { key: 'CPD points', value: cpd.points },
  { key: 'Licence classes', value: cpd.licenceClasses.join(' · ') },
  { key: 'Renewal', value: cpd.renewalPeriod },
  { key: 'Approved by', value: cpd.approvalRef.label },
] : [];

// ASQA branch. The schema guarantees partnerRto exists iff the model is asqa-accredited,
// but the layout still guards on both so a template change cannot render a partner block
// without a partner. The RTO partner delivers and issues the credential; ABE publishes.
const asqa = authorityModel === 'asqa-accredited' && partnerRto ? partnerRto : null;
const asqaCredential = asqa?.credential ?? 'Statement of Attainment';
// The per-course ASQA footer legal disclosure (location 3 of the 7 the ASQA disclosure
// framework requires per course page), owned by the layout so no ASQA page can ship without
// it. Prepended to the page's own disclaimers in the Sources footer.
//
// Worded to the framework's prescribed form: it frames ABE positively as the "authorised
// third-party enrolment partner" rather than repeating "ABE is not a registered training
// organisation". That "not an RTO" statement is still made twice on the page - by the
// SITEWIDE compliance footer (.f-asqa in SourcesFooter, a separate required disclosure) and
// by the #rto-partner PartnerDisclosure section - so nothing is lost; this just stops the
// footer stating it two ways four lines apart.
const asqaDisclaimer = asqa
  ? `<p>This website is operated by ABE Education (ABN 64 125 455 272) as an authorised third-party enrolment partner. This course is delivered and assessed by ${asqa.name}, a nationally recognised Registered Training Organisation (RTO ${asqa.rtoNumber}) accredited by the Australian Skills Quality Authority (ASQA), which issues the ${asqaCredential} on completion.</p>`
  : '';

// Absolute URL for the hero image, for the Course ImageObject (multimodal SEO).
const heroImg = hero.artefactImg
  ? (hero.artefactImg.startsWith('http') ? hero.artefactImg : new URL(hero.artefactImg, canonical).href)
  : null;

// Single server-rendered JSON-LD @graph, built from typed frontmatter.
// recognizedBy is conditional on the authority model (state-approved only).
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Course', '@id': canonical + '#course', name: courseName,
      description: courseDescription,
      provider: { '@type': 'Organization', name: 'ABE Education', url: 'https://www.abeeducation.edu.au' },
      inLanguage: 'en-AU',
      ...(heroImg ? { image: { '@type': 'ImageObject', contentUrl: heroImg, caption: hero.artefactAlt, inLanguage: 'en-AU' } } : {}),
      offers: { '@type': 'Offer', price: priceNumber, priceCurrency: 'AUD', category: 'Tuition', availability: 'https://schema.org/InStock', url: canonical },
      hasCourseInstance: { '@type': 'CourseInstance', courseMode: 'online', ...(courseWorkload ? { courseWorkload } : {}) },
    },
    {
      '@type': 'EducationalOccupationalCredential', '@id': canonical + '#credential',
      name: credentialName, credentialCategory,
      // state-approved-direct: the regulator recognises the credential (QLD/TAS yes, WA no).
      // asqa-accredited: the RTO partner is credited as the issuing organisation — never ABE.
      ...(regulator ? { recognizedBy: { '@type': 'GovernmentOrganization', name: regulator.name, url: regulator.url } } : {}),
      ...(asqa ? { recognizedBy: { '@type': 'Organization', name: asqa.name, identifier: `RTO ${asqa.rtoNumber}`, ...(asqa.url ? { url: asqa.url } : {}) } } : {}),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumb.map((b, i) => ({ '@type': 'ListItem', position: i + 1, name: b.name, item: b.item })),
    },
    // Field order here is load-bearing: it is what keeps the rendered JSON-LD
    // byte-identical to the pre-refactor output. Do not reorder.
    ...expertData.map((e) => ({
      '@type': 'Person', name: e.name, jobTitle: e.jobTitle,
      ...(e.portrait ? { image: e.portrait.src } : {}),
      sameAs: e.linkedin,
    })),
  ],
};
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
  sticky={sticky}
  authority={course.authorityModel}
  ogImage={ogImage}
  noindex={course.noindex}
  crumbs={breadcrumb}
  reviewed={reviewedBy}
>
  <Hero {...hero} cta={cta} />
  {/* Jump nav sits below the hero: it only sticks once you scroll past it. */}
  <WayfinderNav items={nav} cta={cta} />
  <slot />
  {cpd && (
    <Section id="cpd-points" bg="bg-alt" eyebrow="What you need" h2="How many CPD points does this course give you?">
      <FactGrid items={cpdFacts} />
      <p class="cpd-approval-note">Listed as an approved CPD activity by <a href={cpd.approvalRef.href}>{cpd.approvalRef.label}</a>.</p>
    </Section>
  )}
  {cpd?.matrix && (
    <Section id="cpd-matrix" eyebrow="Compare" h2="Where else this counts">
      <CpdMatrix states={cpd.matrix.states} rows={cpd.matrix.rows} caption={cpd.matrix.caption} />
    </Section>
  )}
  {cpd?.bundle && (
    <Section id="cpd-bundle" bg="bg-alt" eyebrow="Bundle and save time" h2="Complete your full CPD requirement in one order">
      <BundleOffer {...cpd.bundle} />
    </Section>
  )}
  {asqa && (
    <Section id="rto-partner" bg="bg-alt" eyebrow="Delivered with our RTO partner">
      <PartnerDisclosure
        partner={asqa.name}
        rto={asqa.rtoNumber}
        units={asqa.units}
        credential={asqaCredential}
      />
    </Section>
  )}
  <CtaBand headingHtml={ctaBand.headingHtml} sub={ctaBand.sub} cta={ctaBand.cta} />
  <SourcesFooter sources={footerSources} disclaimersHtml={asqaDisclaimer + disclaimersHtml} />
</BaseLayout>
