---
import BaseLayout from '../layouts/BaseLayout.astro';
import WayfinderNav from '../components/WayfinderNav.astro';
import Section from '../components/Section.astro';
import AnswerCapsule from '../components/AnswerCapsule.astro';
import TopicGrid from '../components/TopicGrid.astro';
import HubCard from '../components/HubCard.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import Faq from '../components/Faq.astro';
import Note from '../components/Note.astro';
import VerifiedSources from '../components/VerifiedSources.astro';
import CtaBand from '../components/CtaBand.astro';
import SourcesFooter from '../components/SourcesFooter.astro';
import ProcessTrack from '../components/ProcessTrack.astro';
import Placeholder from '../components/Placeholder.astro';
import type { TopicCard } from '../types/course';
import { faqsCpd } from '../data/faqs-cpd';

const canonical = 'https://www.abeeducation.edu.au/cpd';
const cta = { href: '#choose-state', label: 'Find your state’s CPD' };

// Single source for the visible breadcrumbs and the JSON-LD BreadcrumbList below, so
// the two cannot drift. Hub pages are reviewed by Dominic Ogburn, not Warwick Smith.
const crumbs = [
  { name: 'Home', item: 'https://www.abeeducation.edu.au/' },
  { name: 'CPD Courses', item: canonical },
];
// No "Developed and reviewed by" section on a hub page, so the name points at the
// reviewer's profile rather than an anchor that would go nowhere.
const reviewed = { name: 'Dominic Ogburn', href: 'https://www.linkedin.com/in/dominic-ogburn', date: '10 July 2026' };

const nav = [
  { label: 'What is CPD', href: '#what', sectionId: 'what' },
  { label: 'Choose your state', href: '#choose-state', sectionId: 'choose-state' },
  { label: 'Why ABE', href: '#why', sectionId: 'why' },
  { label: 'By state', href: '#compare', sectionId: 'compare' },
  { label: 'FAQ', href: '#faq', sectionId: 'faq' },
];

// State entry points. These were TopicGrid cards with a hand-built "coming soon" span,
// inline-styled because scoped styles cannot reach TopicGrid's set:html body. HubCard
// already models exactly this shape - state badge, title, description, and a live/soon
// distinction - and it swaps <a> for <div> when soon, so an unavailable card is not a
// link at all rather than a link that looks disabled. No inline style, no new component.
//
// Tasmania is now LIVE. /cpd-tas shipped, and this hub was still advertising it as coming
// soon, dead-ending a page that exists. NSW and WA remain genuinely unbuilt (B3).
const stateCards = [
  { state: 'Tasmania', title: 'Building · Plumbing · Electrical CPD', href: '/cpd-tas',
    desc: 'Regulator: CBOS Tasmania. ABE is listed as a CPD training provider on the CBOS website.', price: 'from $449' },
  { state: 'New South Wales', title: 'Building CPD', soon: true,
    desc: 'Regulator: Building Commission NSW. Meets the NSW builder CPD criteria under the Home Building Act 1989.' },
  { state: 'Western Australia', title: 'Real Estate CPD', soon: true,
    desc: 'Regulator: Consumer Protection WA. Covers the mandatory real estate CPD points required each year.' },
];

// State comparison. Transposed from the hand-rolled table this replaced: that had states as
// ROWS and facts as columns, ComparisonTable has states as columns and facts as rows. The
// latter is the orientation DESIGN.md describes ("compares named products side by side") and
// matches the owner builder hub, so the two hubs now read the same way. Dimensions are
// unchanged either way, 4 columns by 3 fact rows.
//
// Transposing also makes the component's action row do real work: it carries the same
// live/soon distinction as the state cards above, so Tasmania links to its page and the two
// unbuilt states say so, instead of the table dead-ending.
const cmpColumns = [
  { key: 'tas', label: 'Tasmania', href: '/cpd-tas' },
  { key: 'nsw', label: 'New South Wales', soon: true },
  { key: 'wa', label: 'Western Australia', soon: true },
];
const cmpRows = [
  { label: 'Occupations (ABE CPD)', values: ['Building · Plumbing · Electrical', 'Building', 'Real Estate'] },
  { label: 'Regulator', values: ['CBOS Tasmania', 'Building Commission NSW', 'Consumer Protection WA'] },
  { label: 'How CPD is set', values: [
    'Points per licence period (for example Builder 12 a year, Building Surveyor 30 a year); activities are RTO-accredited or approved by CBOS',
    'Builder CPD under the Home Building Act 1989; self-declaration, with audit',
    '5 CPD points each year from 1 January 2026, at least 1 from each of 3 subject areas (CPD year 1 April to 31 March)',
  ] },
];

// Why ABE — reasons as cards.
const whyCards: TopicCard[] = [
  { tag: '01', title: 'Recognised where it counts', body: 'Listed with CBOS Tasmania, and built to meet the CPD criteria set by Building Commission NSW and Consumer Protection WA.' },
  { tag: '02', title: 'Fully online and self-paced', body: 'Start when you like and finish around work, on any device.' },
  { tag: '03', title: 'Written for the job', body: 'Practical content on current codes, safety and legal responsibilities, not generic filler.' },
  { tag: '04', title: 'Kept current', body: 'Reviewed against the latest regulator requirements so your points still count.' },
  { tag: '05', title: 'Certificate on completion', body: 'A clear record for your CPD log and any audit.' },
];

const footerSources = [
  { label: 'CBOS Tasmania — Continuing Professional Development', href: 'https://www.cbos.tas.gov.au/topics/licensing-and-registration/cpd', verified: 'Verified 10 Jul 2026' },
  { label: 'CBOS Tasmania — CPD training providers (ABE listed)', href: 'https://www.cbos.tas.gov.au/topics/licensing-and-registration/cpd/additional-training-resources', verified: 'Verified 12 Jun 2026' },
  { label: 'Building Commission NSW', href: 'https://www.nsw.gov.au/departments-and-agencies/building-commission', verified: 'Verified 10 Jul 2026' },
  { label: 'Consumer Protection WA — Mandatory CPD (real estate)', href: 'https://www.consumerprotection.wa.gov.au/mandatory-cpd-real-estate', verified: 'Verified 10 Jul 2026' },
  { label: 'Occupational Licensing Act 2005 (Tas) s.4 · CPD Determination 2018', href: 'https://www.cbos.tas.gov.au/topics/licensing-and-registration/cpd', verified: 'via CBOS' },
  { label: 'Home Building Act 1989 (NSW)', href: 'https://www.nsw.gov.au/departments-and-agencies/building-commission', verified: 'builder CPD criteria' },
];

const disclaimersHtml = '<b>ABE Education is not a Registered Training Organisation.</b> These are non-accredited CPD courses, not nationally recognised training, so they carry CPD points rather than a qualification. In Tasmania, ABE is listed as a CPD training provider on the CBOS website; in New South Wales and Western Australia its CPD is built to meet the criteria set by the Building Commission NSW and Consumer Protection WA respectively. Government requirements verified 10 July 2026; CPD point tables and fees are reviewed by regulators (often around 1 July), so confirm the current figures with your regulator before you rely on them.';

// JSON-LD — hub page type: ItemList of Course + BreadcrumbList. No single Course.offers, no RTO claim.
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'ItemList', name: 'ABE Education CPD Courses by State',
      itemListElement: [
        { '@type': 'ListItem', position: 1, url: 'https://www.abeeducation.edu.au/cpd-tas',
          item: { '@type': 'Course', name: 'Tasmania CPD (Building, Plumbing, Electrical)',
            description: 'Online CPD for Tasmanian building-industry licence holders. ABE is listed as a CPD training provider with CBOS Tasmania.',
            provider: { '@type': 'Organization', name: 'ABE Education', url: 'https://www.abeeducation.edu.au' }, inLanguage: 'en-AU' } },
        { '@type': 'ListItem', position: 2, url: 'https://www.abeeducation.edu.au/cpd-nsw',
          item: { '@type': 'Course', name: 'NSW Building CPD',
            description: 'Online builder CPD meeting the NSW criteria under the Home Building Act 1989, administered by Building Commission NSW.',
            provider: { '@type': 'Organization', name: 'ABE Education', url: 'https://www.abeeducation.edu.au' }, inLanguage: 'en-AU' } },
        { '@type': 'ListItem', position: 3, url: 'https://www.abeeducation.edu.au/cpd-wa',
          item: { '@type': 'Course', name: 'WA Real Estate CPD',
            description: 'Online real estate CPD covering the mandatory points required by Consumer Protection WA.',
            provider: { '@type': 'Organization', name: 'ABE Education', url: 'https://www.abeeducation.edu.au' }, inLanguage: 'en-AU' } },
      ] },
    { '@type': 'BreadcrumbList',
      itemListElement: crumbs.map((c, i) => ({ '@type': 'ListItem', position: i + 1, name: c.name, item: c.item })) },
  ],
};
---
<BaseLayout
  title="CPD Courses for Trade Licences - ABE Education"
  description="Online CPD to keep your building or real estate licence current. Listed with CBOS Tasmania, and built to meet the NSW and WA regulator criteria. Choose your state."
  canonical={canonical}
  schema={schema}
  sticky={{ label: 'CPD Courses', sub: 'building & real estate', price: '3 states', cta: { href: '#choose-state', label: 'Choose your state' } }}
  crumbs={crumbs}
  reviewed={reviewed}
>
  <section class="hero" id="top">
    <div class="wrap">
      <div>
        <span class="eyebrow">Continuing Professional Development <span class="e-dot">•</span> Delivered by ABE Education</span>
        <h1 class="h1">CPD courses that keep your licence current<span class="dot">.</span></h1>
        <span class="updated">Updated July 2026</span>
        <p class="lede">Online CPD that counts toward your licence renewal, built for building and property professionals across Australia. Pick your state to see the courses and the points they carry.</p>
        <ul class="hero-ticks">
          <li><b>Listed with CBOS Tasmania</b>, and built to meet the CPD criteria of Building Commission NSW and Consumer Protection WA</li>
          <li><b>100% online and self-paced</b>, complete it around work</li>
          <li><b>Certificate on completion</b>, for your CPD log and any audit</li>
        </ul>
        <div class="hero-cta">
          <a class="btn-primary" href="#choose-state">Find your state’s CPD</a>
          <a class="btn-secondary" href="#why">Why ABE</a>
        </div>
        <div class="proof">
          <span class="stat"><span class="n num">3</span> states covered</span>
          <span class="stat"><span class="n num">100%</span> online, self-paced</span>
          <span class="stat"><span class="n">Listed with</span> CBOS Tasmania</span>
        </div>
        <ProcessTrack steps="Pick your state → Complete online → Record CPD points" />
      </div>
      <div class="z-img">
        <Placeholder ratio="r54" desc="A CPD certificate of completion shown in product context on a tablet, with a building and property work setting behind it." spec="5:4 · warm tone · ~640×512" />
      </div>
    </div>
  </section>

  {/* Jump nav sits below the hero: it only sticks once you scroll past it. */}
  <WayfinderNav items={nav} cta={cta} />

  <Section id="what" eyebrow="The basics" h2="What is CPD, and who needs it?">
    <AnswerCapsule>Continuing Professional Development (CPD) is the ongoing training licensed trades and property professionals complete to keep their skills current and their licence in good standing. Most building and real estate regulators set a minimum number of CPD points or hours each renewal period. ABE Education delivers CPD you complete online, at your own pace.</AnswerCapsule>
    <div class="measure" style="max-width:62ch">
      <p>If you hold a builder, plumber, electrician, building surveyor or real estate licence, your regulator expects you to keep learning across the life of that licence. CPD is how you show it. The rules differ by state and by occupation, so the right course depends on where you are licensed and what you are licensed to do. This page points you to the CPD that applies to your state, then each state page lists the individual courses and the points they carry.</p>
      <p style="margin-top:var(--s-sm)">ABE Education develops and delivers its CPD courses directly. You study online, finish on your own schedule, and receive a certificate recording the CPD you have completed for your own records and any audit.</p>
    </div>
  </Section>

  <Section id="choose-state" bg="bg-alt" eyebrow="Choose your state" h2="Find the CPD that applies to your licence">
    <AnswerCapsule>ABE currently offers CPD in three states. Pick yours to see the courses and points that apply, and the fees for each.</AnswerCapsule>
    <div class="hub-grid">{stateCards.map((c) => <HubCard {...c} />)}</div>
    <Note><b>Fees:</b> course fees are shown on each state page, alongside the points each course carries. Need several points at once? The <a href="/cpd-tas#bundles">Tasmanian trade bundles</a> cover a full year in one purchase, from $449.</Note>
    <VerifiedSources date="10 July 2026" facts="Regulator and CPD requirement fact-checked per state" sources={[
      { label: 'CBOS Tasmania — CPD', href: 'https://www.cbos.tas.gov.au/topics/licensing-and-registration/cpd' },
      { label: 'Building Commission NSW', href: 'https://www.nsw.gov.au/departments-and-agencies/building-commission' },
      { label: 'Consumer Protection WA — Mandatory CPD (real estate)', href: 'https://www.consumerprotection.wa.gov.au/mandatory-cpd-real-estate' },
    ]} />
  </Section>

  <Section id="why" eyebrow="Why ABE" h2="Why choose ABE Education for CPD">
    <AnswerCapsule>Professionals choose ABE for CPD because it is recognised where it counts, fully online, written for the job, kept current, and backed by a certificate you can put straight into your CPD log.</AnswerCapsule>
    <TopicGrid items={whyCards} />
    <p class="howline" style="margin-top:var(--s-lg)"><b>100% online</b> · Listed with CBOS Tasmania · Trusted by Australian tradespeople</p>
    <Note maroon>ABE Education develops and delivers this CPD directly. These are non-accredited CPD courses, not nationally recognised training, so they carry CPD points rather than a qualification.</Note>
  </Section>

  <Section id="compare" bg="bg-alt" eyebrow="At a glance" h2="CPD by state and occupation">
    <AnswerCapsule>How CPD is measured depends on your state and licence. Here is the picture at a glance, then your state page lists the points each ABE course carries.</AnswerCapsule>
    <ComparisonTable columns={cmpColumns} rows={cmpRows} ctaLabel="View CPD" />
    <Note>Tasmanian points vary by licence class. As a guide, builders need 12 points a year (36 over a three-year licence), building surveyors 30 a year, and electricians, plumbers and gas-fitters 12 a year. Your state page lists the points each ABE course carries so you can plan the shortest path to your total.</Note>
    <VerifiedSources date="10 July 2026" facts="CPD points framework fact-checked per state" sources={[
      { label: 'CBOS Tasmania — CPD (Occupational Licensing Act 2005 s.4; CPD Determination 2018)', href: 'https://www.cbos.tas.gov.au/topics/licensing-and-registration/cpd' },
      { label: 'Consumer Protection WA — Mandatory CPD (real estate)', href: 'https://www.consumerprotection.wa.gov.au/mandatory-cpd-real-estate' },
    ]} />
  </Section>

  <Section id="faq" eyebrow="FAQ" h2="Common questions">
    <Faq items={faqsCpd} />
  </Section>

  <CtaBand
    eyebrow="Get started"
    headingHtml={'Ready to top up your CPD<span class="dot">?</span>'}
    sub="Choose your state to see the courses that count toward your licence, the points they carry, and the fees."
    cta={{ href: '#choose-state', label: 'Choose your state', microcopy: 'Three states · 100% online · certificate on completion' }}
  />

  <SourcesFooter sources={footerSources} disclaimersHtml={disclaimersHtml} />
</BaseLayout>
