---
// TRIAL route for the flexible-build manifest system. Renders any manifest in
// src/content/pages/ at /preview/<slug>, alongside (not replacing) the live MDX
// course pages. Scoped under /preview to avoid colliding with the real slugs;
// noindex-safe because each manifest canonicals to its production URL, and
// /preview is excluded from the sitemap (astro.config.mjs).
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import WayfinderNav from '../../components/WayfinderNav.astro';
import SectionRenderer from '../../components/SectionRenderer.astro';
import CtaBand from '../../components/CtaBand.astro';
import SourcesFooter from '../../components/SourcesFooter.astro';
import { buildSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((entry) => ({ params: { slug: entry.id }, props: { p: entry.data } }));
}

const { p } = Astro.props;

// Everything below is DERIVED from the manifest: the wayfinder nav, the section
// markers, the forward "Next:" links, the sticky price, the schema graph.
const navSections = p.sections.filter((s) => s.nav);
const nav = navSections.map((s) => ({ label: s.nav as string, href: '#' + s.id, sectionId: s.id }));
const nextFor = (i: number) => {
  const rest = p.sections.slice(i + 1).find((s) => s.nav);
  return rest ? { label: rest.nav as string, href: '#' + rest.id } : undefined;
};
const crumbs = p.breadcrumbs.map((b) => ({ name: b.name, item: b.item }));
const heading = p.course.name + ', ' + p.price.display;
const schema = buildSchema(p);
---
<BaseLayout
  title={p.title}
  description={p.description}
  canonical={p.canonical}
  schema={schema}
  sticky={{ label: p.sticky.label, sub: p.sticky.sub, price: p.price.display, cta: p.sticky.cta }}
  crumbs={crumbs}
>
  <Hero
    eyebrow={p.hero.eyebrow}
    h1Html={p.hero.h1Html}
    updated={p.updated}
    subhead={p.hero.subhead}
    ticks={p.hero.ticks}
    cta={p.hero.cta}
    proof={p.hero.proof}
    howItWorks={p.hero.howItWorks}
    artefactDesc={p.hero.artefact.desc}
    artefactSpec={p.hero.artefact.spec}
    artefactRatio={p.hero.artefact.ratio}
  />

  <WayfinderNav items={nav} cta={p.hero.cta} />

  {p.sections.map((section, i) => (
    <SectionRenderer section={section} index={i} total={p.sections.length} next={nextFor(i)} />
  ))}

  <CtaBand headingHtml={heading + '<span class="dot">.</span>'} sub={p.hero.subhead} cta={p.hero.cta} />
  <SourcesFooter sources={p.sources} updated={p.updated} disclaimersHtml={p.disclaimersHtml} />
</BaseLayout>
