---
// Living component library for the ABE Education site. Imports and renders every shared
// component with representative example data, using the real global.css and fonts, so it
// stays accurate because it renders the actual components (not copies). Internal only:
// noindex + excluded from the sitemap (see astro.config.mjs sitemap filter).
import '../styles/global.css';

import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import PageBar from '../components/PageBar.astro';
import WayfinderNav from '../components/WayfinderNav.astro';
import CtaBand from '../components/CtaBand.astro';
import SourcesFooter from '../components/SourcesFooter.astro';
import Section from '../components/Section.astro';
import ZSplit from '../components/ZSplit.astro';
import ZSection from '../components/ZSection.astro';
import Placeholder from '../components/Placeholder.astro';
import AnswerCapsule from '../components/AnswerCapsule.astro';
import Note from '../components/Note.astro';
import CanCant from '../components/CanCant.astro';
import Stepper from '../components/Stepper.astro';
import TopicGrid from '../components/TopicGrid.astro';
import ModuleRows from '../components/ModuleRows.astro';
import HubCard from '../components/HubCard.astro';
import FactGrid from '../components/FactGrid.astro';
import PriceCard from '../components/PriceCard.astro';
import BundleOffer from '../components/BundleOffer.astro';
import BundleCard from '../components/BundleCard.astro';
import type { Bundle } from '../components/BundleCard.astro';
import Faq from '../components/Faq.astro';
import ProcessTrack from '../components/ProcessTrack.astro';
import CpdMatrix from '../components/CpdMatrix.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import Credentials from '../components/Credentials.astro';
import ExpertCredentials from '../components/ExpertCredentials.astro';
import ReviewQuote from '../components/ReviewQuote.astro';
import VerifiedSources from '../components/VerifiedSources.astro';
import PartnerDisclosure from '../components/PartnerDisclosure.astro';
import TrustBand from '../components/TrustBand.astro';
import TrustStats from '../components/TrustStats.astro';
import InsurancePartner from '../components/InsurancePartner.astro';
import SectionWayfinder from '../components/SectionWayfinder.astro';
import ArrowRight from '../components/ArrowRight.astro';

const ctaEx = { href: '#', label: 'Get your certificate — $179', microcopy: 'Instant access after payment' };

const glance = [
  { key: 'Price', value: '$179', note: 'GST-free. The permit fee is separate.' },
  { key: 'Delivery', value: 'Online', note: 'Self-paced, finish in a few hours.' },
  { key: 'Assessment', value: '80%', note: 'Online quiz, up to 3 attempts.' },
  { key: 'Certificate', value: '5 yrs', note: 'Valid five years for your permit.' },
];
const topics = [
  { tag: '01', title: 'Your responsibilities', body: 'What you take on as the <b>builder</b> for your own home.' },
  { tag: '02', title: 'Safety and the site', body: 'WHS duties and the <b>National Construction Code</b>.' },
  { tag: '03', title: 'Costing and trades', body: 'Estimate, budget, and engage <b>licensed trades</b>.' },
];
const steps = [
  { title: 'Enrol online', body: 'Pay and get instant access. Card or Afterpay.' },
  { title: 'Complete the course', body: 'Work through the modules at your own pace, then the quiz.' },
  { title: 'Get your certificate', body: 'Emailed the moment you pass.' },
];
// Two rows with outcomes and one without, so the specimen shows the optional fields both
// present and absent - a state that has not authored outcomes yet must still render cleanly.
const moduleRowsEx = [
  { tag: 'Group 01', modules: 'Modules 1-2', title: 'Getting started', body: 'Course Introduction, and the Key Responsibilities of an Owner Builder.', outcome: 'set up your build, and explain what you take on when you sign as the owner builder.' },
  { tag: 'Group 02', modules: 'Modules 3, 11, 12', title: 'Legal &amp; safety obligations', body: 'Work Health and Safety, Obligations Under the QBCC Act 1991, and Approvals and Inspections.', outcome: 'apply work health and safety on your own site.' },
  { tag: '03', title: 'A group with no module range or outcome', body: 'How a state that has not authored the optional fields still renders.' },
];
const priceRows = [
  { label: 'Course fee', sub: 'Paid to ABE Education, GST-free', amount: '$179.00' },
  { label: 'Government permit fee', sub: 'Paid to the regulator when you lodge', amount: '$493.59' },
  { label: 'Ready-to-build total', sub: 'A budgeting figure only', amount: '$672.59', isTotal: true },
];
// Third item deliberately omits price/cta so the specimen shows the soon state, which is
// otherwise invisible until a real bundle is unpriced.
const bundleCardEx: Bundle[] = [
  { trade: 'Builders', title: 'Example Builder bundle', blurb: 'Twelve approved courses covering a full year in one purchase.',
    points: '12', delivery: 'Online', perPoint: '$42', price: '$499', rrp: '$1,188', cta: { href: '#', label: 'View the bundle' } },
  { trade: 'Plumbers', title: 'Example Plumber bundle', blurb: 'Eleven approved courses covering most of a year.',
    points: '11', delivery: 'Online', perPoint: '$41', price: '$449', rrp: '$1,089', cta: { href: '#', label: 'View the bundle' },
    foot: 'Add 1 further point from another approved activity to reach 12.' },
  { trade: 'Electricians', title: 'Example unpriced bundle', blurb: 'Shows the state used when a price is not confirmed yet.',
    points: '12', delivery: 'Online' },
];
// The five NSW owner builder units, so the specimen shows the multi-unit case as well as
// the single-unit White Card one. A component that only ever renders one item in its
// gallery is a component whose list behaviour nobody has looked at.
const partnerUnitsEx = [
  { code: 'CPCCWHS2001', name: 'Apply WHS requirements, policies and procedures in the construction industry' },
  { code: 'CPCCOM2001', name: 'Read and interpret plans and specifications' },
  { code: 'CPCCCM1011', name: 'Undertake basic estimation and costing' },
  { code: 'CPCCOM1013', name: 'Plan and organise work' },
  { code: 'CPCCOM1014', name: 'Conduct workplace communication' },
];
const faqExamples = [
  { q: 'Is the course mandatory?', a: 'Yes, the regulator requires an approved course before it issues your permit.', open: true },
  { q: 'How long does it take?', a: 'Most people finish online in a few hours, at their own pace.' },
];
const people = [{
  name: 'Example Reviewer',
  role: 'Compliance & Currency Reviewer (demo)',
  creds: 'Demonstration credential line · shown to illustrate the Credentials component',
  bio: [
    'Placeholder biography copy showing how the card renders a mono credential line above body paragraphs.',
    'A second paragraph demonstrates a multi-paragraph bio.',
  ],
  linkedin: '#',
}];
const vSources = [
  { label: 'Regulator — Owner builder permit', href: '#' },
  { label: 'Building Act (example)', href: '#' },
];
const footerSources = [
  { label: 'Regulator — Owner builder permit', href: '#', verified: 'Verified 14 Jul 2026' },
  { label: 'Building Act (example)', href: '#', verified: 'legislation' },
];
const navItems = [
  { label: 'The course', href: '#course', sectionId: 'course' },
  { label: 'Cost', href: '#cost', sectionId: 'cost' },
  { label: 'FAQ', href: '#faq', sectionId: 'faq' },
];
const crumbs = [
  { name: 'Home', item: '#' },
  { name: 'Owner Builder Training', item: '#' },
  { name: 'Example Course', item: '#' },
];
const reviewed = { name: 'Example Reviewer', href: '#', date: '14 Jul 2026' };
const cpdStates = ['TAS', 'NSW', 'WA'];
const cpdRows = [
  { industry: 'Building', cells: [{ href: '#' }, { href: '#' }, null] },
  { industry: 'Real estate', note: 'annual points', cells: [null, null, { href: '#' }] },
];
const cmpColumns = [
  { key: 'qld', label: 'QLD', href: '#' },
  { key: 'wa', label: 'WA', href: '#' },
  { key: 'tas', label: 'TAS', href: '#' },
  { key: 'act', label: 'ACT', soon: true },
];
const cmpRows = [
  { label: 'Price', values: ['$179', '$179', '$185', '—'] },
  { label: 'Authority', values: ['QBCC-approved', 'Form 75 support', 'CBOS-approved', '—'] },
  { label: 'Modules', values: ['18', '13', '12', '—'] },
];
const heroEx = {
  eyebrow: 'Owner Builder · Approved',
  h1Html: 'The example owner builder course, online<span class="dot">.</span>',
  updated: 'Updated July 2026',
  subhead: 'A representative hero. Complete the course the regulator requires, online at your own pace, then lodge your certificate with your application.',
  ticks: ['<b>Approved course material</b>', '<b>100% online and self-paced</b>', '<b>Certificate of Completion</b>', '<b>Valid five years</b>'],
  cta: ctaEx,
  proof: [{ n: 'QBCC', text: 'approved material' }, { n: '31,000+', text: 'students trained' }, { n: '2007', text: 'training since' }],
  howItWorks: 'Enrol → Complete online → Get certificate → Apply',
  artefactDesc: 'Example hero artefact.',
  artefactSpec: '4:5 · warm tone',
  artefactImg: '/images/qld-owner-builder-course-hero.avif',
  artefactAlt: 'Example hero image of house plans with a home under construction rising behind.',
  // `as const` so the literal narrows to Hero's `'r54' | 'r45'` union rather than
  // widening to string, which does not satisfy the prop type.
  artefactRatio: 'r45' as const,
};

// Design tokens, mirrored from src/styles/global.css :root.
const colorTokens = [
  { group: 'Accent', items: [
    { v: '--maroon', hex: '#800000', note: 'sole brand accent, ≤10% of any screen' },
    { v: '--maroon-dark', hex: '#5a0000', note: 'pressed / hover-on-dark' },
    { v: '--verify', hex: '#2f5d8c', note: 'sourced + verified facts only' },
    { v: '--gold', hex: '#d4a843', note: 'on-dark accent' },
    { v: '--ok', hex: '#2e7d5b', note: 'success / verified tick' },
  ] },
  { group: 'Ink & text', items: [
    { v: '--ink', hex: '#1a1a1a', note: 'primary text / dark ground' },
    { v: '--ink-2', hex: '#2a2a2a', note: 'emphasis text' },
    { v: '--ink-3', hex: '#4a4a4a', note: 'body text' },
    { v: '--slate', hex: '#6e6e6e', note: 'labels, captions' },
    { v: '--slate-light', hex: '#9a9a9a', note: 'muted / secondary' },
  ] },
  { group: 'Paper & ground', items: [
    { v: '--paper', hex: '#ffffff' },
    { v: '--paper-alt', hex: '#fafafa' },
    { v: '--paper-warm', hex: '#f7f4ef' },
    { v: '--paper-chrome', hex: 'var(--paper)', note: 'nav / breadcrumb ground' },
  ] },
  { group: 'Rules', items: [
    { v: '--rule', hex: '#e5e7eb', note: 'hairline' },
    { v: '--rule-strong', hex: '#d4d6da', note: 'stronger hairline' },
  ] },
];
const families = [
  { name: 'Archivo', role: 'Display · headlines · figures', cssvar: '--font-display', weights: '500 · 600 · 700' },
  { name: 'DM Sans', role: 'Body copy', cssvar: '--font-body', weights: '400 · 500 · 600 · 700' },
  { name: 'DM Mono', role: 'Labels · captions · source lines', cssvar: '--font-mono', weights: '400 · 500' },
];
const typeScale = [
  { name: 'Display (H1)', font: 'display', size: 'clamp(40px, 6.2vw, 72px)', weight: 700, ls: '-.03em', sample: 'The owner builder course' },
  { name: 'Headline (H2)', font: 'display', size: 'clamp(30px, 3.6vw, 42px)', weight: 600, ls: '-.025em', sample: 'Is this course accredited?' },
  { name: 'Title (H3)', font: 'display', size: '22px', weight: 600, ls: '-.01em', sample: 'Course and White Card bundle' },
  { name: 'Body', font: 'body', size: '17px', weight: 400, ls: 'normal', sample: 'Complete the course the regulator requires before you apply for your permit.' },
  { name: 'Label / eyebrow', font: 'mono', size: '11px', weight: 500, ls: '.18em', upper: true, sample: 'At a glance' },
];
const spacingScale = [
  { v: '--s-3xs', px: 4 }, { v: '--s-2xs', px: 8 }, { v: '--s-xs', px: 12 },
  { v: '--s-sm', px: 16 }, { v: '--s-md', px: 24 }, { v: '--s-lg', px: 32 },
  { v: '--s-xl', px: 48 }, { v: '--s-2xl', px: 72 }, { v: '--s-3xl', px: 112 },
];
const layoutWidths = [ { v: '--max', px: 1200, note: 'page max' }, { v: '--content', px: 980, note: 'reading content' } ];
const radii = [ { name: 'sm', px: 5 }, { name: 'md', px: 6, note: 'buttons, cards' }, { name: 'lg', px: 8, note: 'price card, panels' } ];

const groups = [
  { id: 'foundations', label: 'Foundations' },
  { id: 'chrome', label: 'Page chrome' },
  { id: 'layout', label: 'Sections & layout' },
  { id: 'content', label: 'Content blocks' },
  { id: 'trust', label: 'Trust & sourcing' },
  { id: 'nav', label: 'Navigation & inline' },
];
---
<html lang="en-AU">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <title>ABE Component Library</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {/* Non-render-blocking font load, matching BaseLayout.astro - see that file for why. */}
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700&family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700&family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" /></noscript>
</head>
<body class="sg">
  <header class="sg-head">
    <span class="sg-kicker">Internal · noindex</span>
    <h1>Component library</h1>
    <p>Every shared component on the ABE site, rendered live with example data and the real design tokens. This page renders the actual components, so it never drifts from production. Grouped by role; each specimen shows the component name and its key props.</p>
    <nav class="sg-toc">
      {groups.map((g) => <a href={`#g-${g.id}`}>{g.label}</a>)}
    </nav>
  </header>

  <!-- ===== FOUNDATIONS ===== -->
  <section class="sg-group" id="g-foundations">
    <h2 class="sg-group-title">Foundations</h2>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Colour</span><span class="sg-desc">One maroon accent, a verify-blue reserved for sourced facts, warm paper grounds. Tinted neutrals, never pure black.</span></div>
      <div class="sg-demo">
        {colorTokens.map((g) => (
          <Fragment>
            <div class="sg-sub">{g.group}</div>
            <div class="sg-swatches">
              {g.items.map((c) => (
                <div class="sg-swatch">
                  <div class="sg-chip" style={`background:${c.hex}`}></div>
                  <span class="n">{c.v}</span>
                  <span class="hex">{c.hex}</span>
                  {c.note && <span class="note">{c.note}</span>}
                </div>
              ))}
            </div>
          </Fragment>
        ))}
      </div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Type</span><span class="sg-desc">Three voices: Archivo for display and figures, DM Sans for reading, DM Mono for labels and captions.</span></div>
      <div class="sg-demo">
        <div class="sg-fams">
          {families.map((f) => (
            <div class="sg-fam">
              <div class="aa" style={`font-family:var(${f.cssvar})`}>Aa</div>
              <div class="fn">{f.name}</div>
              <div class="fr">{f.role}</div>
              <div class="fw">{f.weights}</div>
            </div>
          ))}
        </div>
        <div class="sg-sub">Scale</div>
        {typeScale.map((t) => (
          <div class="sg-type-row">
            <div class="meta">{t.name} · {t.size} · {t.weight}{t.ls !== 'normal' ? ' · ' + t.ls : ''}</div>
            <div style={`font-family:var(--font-${t.font});font-size:${t.size};font-weight:${t.weight};letter-spacing:${t.ls};line-height:1.1;color:var(--ink);${t.upper ? 'text-transform:uppercase;' : ''}`}>{t.sample}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Spacing</span><span class="sg-desc">Rhythm and padding scale. Section padding runs up to --s-3xl (112px).</span></div>
      <div class="sg-demo">
        <div class="sg-scale">
          {spacingScale.map((s) => (
            <div class="sg-bar-row">
              <span class="lbl">{s.v}</span>
              <span class="sg-bar" style={`width:${s.px}px`}></span>
              <span class="px">{s.px}px</span>
            </div>
          ))}
        </div>
        <div class="sg-sub">Layout widths</div>
        <div class="sg-scale">
          {layoutWidths.map((w) => (
            <div class="sg-bar-row"><span class="lbl">{w.v}</span><span class="px">{w.px}px · {w.note}</span></div>
          ))}
        </div>
      </div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Radius</span><span class="sg-desc">Small, flat rounding, applied directly (no CSS variable). Nothing pill-shaped.</span></div>
      <div class="sg-demo">
        <div class="sg-radii">
          {radii.map((r) => (
            <div class="sg-radius">
              <div class="box" style={`border-radius:${r.px}px`}></div>
              <div class="lbl">{r.name} · {r.px}px</div>
              {r.note && <div class="note">{r.note}</div>}
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Buttons</span><span class="sg-desc">Primary (the money CTA), secondary (low-emphasis), and the inline text link with the fly arrow. One money-CTA verb per page; hover moves ink to maroon.</span><span class="sg-props">.btn-primary · .btn-secondary · .btn-link</span></div>
      <div class="sg-demo sg-btns">
        <a class="btn-primary" href="#">Get your certificate — $179</a>
        <a class="btn-secondary" href="#">Get an insurance quote</a>
        <a class="btn-link" href="#">See who needs a permit <ArrowRight /></a>
      </div>
    </div>
  </section>

  <!-- ===== PAGE CHROME ===== -->
  <section class="sg-group" id="g-chrome">
    <h2 class="sg-group-title">Page chrome</h2>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">SiteHeader</span><span class="sg-desc">Top nav with click-open megamenus. Self-contained, no props.</span></div>
      <div class="sg-demo sg-demo--bleed"><SiteHeader /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Hero</span><span class="sg-desc">Above-the-fold stack: eyebrow, H1, ticks, CTA, proof, artefact.</span><span class="sg-props">eyebrow · h1Html · subhead · ticks[] · cta · proof[] · howItWorks · artefact*</span></div>
      <div class="sg-demo sg-demo--bleed"><Hero {...heroEx} /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">PageBar</span><span class="sg-desc">Breadcrumb + reviewer/freshness bar.</span><span class="sg-props">crumbs[] · reviewed?</span></div>
      <div class="sg-demo sg-demo--bleed"><PageBar crumbs={crumbs} reviewed={reviewed} /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">WayfinderNav</span><span class="sg-desc">On-this-page sticky nav with a money CTA.</span><span class="sg-props">items[] · cta</span></div>
      <div class="sg-demo sg-demo--bleed"><WayfinderNav items={navItems} cta={ctaEx} /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">CtaBand</span><span class="sg-desc">Closing conversion band before the footer.</span><span class="sg-props">eyebrow? · headingHtml · sub · cta</span></div>
      <div class="sg-demo sg-demo--bleed"><CtaBand eyebrow="Ready?" headingHtml={'Ready to get started<span class="dot">?</span>'} sub="A representative closing CTA band." cta={ctaEx} /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">SourcesFooter</span><span class="sg-desc">Global site footer: link columns, publisher/RTO/enrolment block, sitewide ASQA disclosure, then page-foot sources + disclaimers.</span><span class="sg-props">sources[] · abn? · updated? · disclaimersHtml</span></div>
      <div class="sg-demo sg-demo--bleed"><SourcesFooter sources={footerSources} abn="64 125 455 272" updated="July 2026" disclaimersHtml="<b>ABE Education is not an RTO.</b> Example disclaimer copy showing how the footer renders sitewide legal lines." /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">StickyCta</span><span class="sg-desc">Viewport-fixed enrol bar (not rendered here to avoid a persistent overlay).</span><span class="sg-props">label · sub? · price · cta</span></div>
      <div class="sg-demo sg-note-line">Renders as a fixed bar pinned to the viewport on course pages. See any live course page.</div>
    </div>
  </section>

  <!-- ===== SECTIONS & LAYOUT ===== -->
  <section class="sg-group" id="g-layout">
    <h2 class="sg-group-title">Sections & layout</h2>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Section</span><span class="sg-desc">Standard content section: eyebrow, H2, tonal ground.</span><span class="sg-props">bg? · id? · marker? · eyebrow? · h2 · slot</span></div>
      <div class="sg-demo sg-demo--bleed">
        <Section bg="bg-alt" eyebrow="At a glance" h2="The facts before you enrol">
          <AnswerCapsule>A Section wraps content with a consistent eyebrow, question-led H2, and tonal paper ground. This capsule sits inside it.</AnswerCapsule>
        </Section>
      </div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">ZSplit</span><span class="sg-desc">Image + body split. `rev` flips the image right.</span><span class="sg-props">rev? · imgRatio? · imgSrc? · imgAlt? · slot</span></div>
      <div class="sg-demo">
        <ZSplit imgDesc="Example split image." imgSpec="4:5 · warm tone">
          <span class="eyebrow"><span class="eyebrow-i">01</span>The course</span>
          <h2 class="h2">A two-column image and body split</h2>
          <AnswerCapsule>The image column top-aligns with the eyebrow. Add <code>rev</code> to place the image on the right.</AnswerCapsule>
        </ZSplit>
      </div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">ZSection</span><span class="sg-desc">A full image-split SECTION: shell, marker + eyebrow + H2 inside the body column, and the forward wayfinder. Use this, never a hand-rolled &lt;section&gt;.</span><span class="sg-props">id? · bg? · marker? · eyebrow? · h2? · rev? · imgRatio? · imgDesc · imgSpec? · imgSrc? · imgAlt? · next? · slot</span></div>
      <div class="sg-demo"><ZSection
        id="sg-zsection"
        marker="02"
        eyebrow="How it works"
        h2="A complete image-split section"
        imgDesc="Example split image."
        imgSpec="4:5 · warm tone"
        next={{ label: 'What it costs', href: '#' }}
      ><AnswerCapsule>ZSection owns the section shell, the marker, the eyebrow, the H2 and the wayfinder. The body is whatever you slot into it.</AnswerCapsule></ZSection></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Placeholder</span><span class="sg-desc">FPO image slot, or a real image via `src`.</span><span class="sg-props">ratio? (r54/r45) · desc · spec? · src? · alt?</span></div>
      <div class="sg-demo sg-two">
        <Placeholder ratio="r54" desc="Landscape FPO placeholder (5:4)." spec="5:4 · warm tone" />
        <Placeholder ratio="r45" desc="Portrait FPO placeholder (4:5)." spec="4:5 · warm tone" />
      </div>
    </div>
  </section>

  <!-- ===== CONTENT BLOCKS ===== -->
  <section class="sg-group" id="g-content">
    <h2 class="sg-group-title">Content blocks</h2>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">AnswerCapsule</span><span class="sg-desc">40–60 word answer capsule under a question heading. `onDark` variant.</span><span class="sg-props">onDark? · slot</span></div>
      <div class="sg-demo"><AnswerCapsule>The answer capsule opens a section with a direct 40 to 60 word answer, sized for AI Overviews and voice snippets. It carries the key fact first.</AnswerCapsule></div>
      <div class="sg-demo sg-demo--dark"><AnswerCapsule onDark>The same capsule on an ink ground, used inside the trust band.</AnswerCapsule></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Note</span><span class="sg-desc">Callout. One per section, type-matched to severity.</span><span class="sg-props">variant? (note/caution) · label? · maroon?</span></div>
      <div class="sg-demo sg-stack">
        <Note><b>Note:</b> the default informational callout.</Note>
        <Note variant="caution" label="Important"><b>Caution:</b> used for serious or legal consequences.</Note>
        <Note maroon><b>Maroon:</b> the accented emphasis variant.</Note>
      </div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">CanCant</span><span class="sg-desc">Two-column what-it-is / what-it-is-not.</span><span class="sg-props">canTitle · can[] · cantTitle · cant[]</span></div>
      <div class="sg-demo">
        <CanCant
          canTitle="What this course is"
          can={['An approved course.', 'Issues a Certificate of Completion.', 'Accepted for your permit.']}
          cantTitle="What it is not"
          cant={['Not nationally recognised.', 'Not delivered by an RTO.', 'Not a builder’s licence.']}
        />
      </div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Stepper</span><span class="sg-desc">Numbered linear process.</span><span class="sg-props">steps[] · maxWidth?</span></div>
      <div class="sg-demo"><Stepper steps={steps} maxWidth="480px" /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">ProcessTrack</span><span class="sg-desc">Hero how-it-works rail from an arrow-joined string.</span><span class="sg-props">steps (string) · label?</span></div>
      <div class="sg-demo"><ProcessTrack steps="Enrol → Complete online → Get certificate → Apply" label="Process" /></div>
    </div>
    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">ModuleRows</span><span class="sg-desc">Syllabus rows: mono key rail, module range, contents, optional outcome. Rows not cards, per DESIGN.md s7 (reference/syllabus). Third row shows the optional fields absent.</span><span class="sg-props">items[] (tag · title · body · modules? · outcome?)</span></div>
      <div class="sg-demo"><ModuleRows items={moduleRowsEx} /></div>
    </div>


    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">TopicGrid</span><span class="sg-desc">Card grid for browsing topics or modules.</span><span class="sg-props">items[] (tag · title · body)</span></div>
      <div class="sg-demo"><TopicGrid items={topics} /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">HubCard</span><span class="sg-desc">Hub spoke card: state, price, soon-state (what TopicGrid's card cannot carry).</span><span class="sg-props">state? · title · desc · price? · href? · soon?</span></div>
      <div class="sg-demo" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
        <HubCard state="QLD" title="QLD Owner Builder" desc="Approved by the QBCC." price="$179" href="#" />
        <HubCard state="WA" title="WA Owner Builder" desc="Supports your Form 75 approval." price="$179" href="#" />
        <HubCard state="ACT" title="ACT Owner Builder" desc="In development." soon />
      </div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">FactGrid</span><span class="sg-desc">At-a-glance fact cells.</span><span class="sg-props">items[] (key · value · note?)</span></div>
      <div class="sg-demo"><FactGrid items={glance} /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">PriceCard</span><span class="sg-desc">Line-item cost breakdown with a total row.</span><span class="sg-props">rows[] (label · sub? · amount · isTotal?) · foot?</span></div>
      <div class="sg-demo"><PriceCard rows={priceRows} foot="Government fees are set by the regulator and reviewed each 1 July." /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">BundleOffer</span><span class="sg-desc">Cross-sell offer with a receipt-style tally.</span><span class="sg-props">eyebrow? · heading · lede · items[] · total · cta · note?</span></div>
      <div class="sg-demo">
        <BundleOffer
          eyebrow="Bundle"
          heading="Course + White Card, the full pathway"
          lede="Do both together and you have the complete evidence in one enrolment."
          items={[{ label: 'Owner builder course', price: '$179' }, { label: 'White Card', sub: 'Unit CPCWHS1001', price: '$99' }]}
          totalLabel="Both together"
          total="$278"
          cta={{ href: '#', label: 'Enrol in the bundle' }}
        />
      </div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">BundleCard</span><span class="sg-desc">Trade-bundle chooser. Distinct from BundleOffer: parallel bundles the reader picks between, not one cross-sell. Third card shows the no-price state.</span><span class="sg-props">items[] (trade · title · blurb · points · courses · price? · rrp? · perPoint? · cta? · foot? · soonLabel?)</span></div>
      <div class="sg-demo">
        <BundleCard items={bundleCardEx} />
      </div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Faq</span><span class="sg-desc">Accordion FAQ (non-essential content only).</span><span class="sg-props">items[] (q · a · open?)</span></div>
      <div class="sg-demo"><Faq items={faqExamples} /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">CpdMatrix</span><span class="sg-desc">Industry × state CPD grid.</span><span class="sg-props">states[] · rows[] · caption?</span></div>
      <div class="sg-demo"><CpdMatrix states={cpdStates} rows={cpdRows} caption="Example CPD availability by state." /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">ComparisonTable</span><span class="sg-desc">State/product-by-state comparison, with a trailing action row.</span><span class="sg-props">columns[] (key · label · href? · soon?) · rows[] (label · values[]) · caption? · ctaLabel?</span></div>
      <div class="sg-demo"><ComparisonTable columns={cmpColumns} rows={cmpRows} caption="Example: owner builder by state." ctaLabel="View course" /></div>
    </div>
  </section>

  <!-- ===== TRUST & SOURCING ===== -->
  <section class="sg-group" id="g-trust">
    <h2 class="sg-group-title">Trust & sourcing</h2>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">Credentials</span><span class="sg-desc">Expert cards for the content-review section.</span><span class="sg-props">people[] (name · role · creds · bio[] · portrait? · profileHref?)</span></div>
      <div class="sg-demo"><Credentials people={people} /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">ExpertCredentials</span><span class="sg-desc">Resolves `experts` collection references, then renders Credentials. Used by course MDX bodies so expert data is not copy-pasted into course frontmatter.</span><span class="sg-props">experts[] (references) · profileBase?</span></div>
      <div class="sg-demo"><ExpertCredentials experts={[{ collection: 'experts', id: 'dominic-ogburn' }, { collection: 'experts', id: 'warwick-smith' }]} profileBase="/experts" /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">ReviewQuote</span><span class="sg-desc">Attributed third-party review. blockquote + cite; carries no rating markup by design (see CLAUDE.md — never AggregateRating).</span><span class="sg-props">quote · name · context? · source? · excerpt?</span></div>
      <div class="sg-demo">
        <div class="rq-grid">
          <ReviewQuote quote="Example review text, quoted word for word from the public profile." name="Example Reviewer" context="Owner builder course" />
          <ReviewQuote quote="An example of a review the source truncated, so it is labelled an excerpt." name="Example Reviewer" context="CPD course" excerpt />
        </div>
      </div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">VerifiedSources</span><span class="sg-desc">Per-section verification ledger (date + facts + sources).</span><span class="sg-props">date · facts? · sources[]</span></div>
      <div class="sg-demo"><VerifiedSources date="14 Jul 2026" facts="Course requirement fact-checked against the current guidance" sources={vSources} /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">TrustBand</span><span class="sg-desc">Dark trust band: stat row plus the authority-model attestation. Owns its own section shell.</span><span class="sg-props">id? · eyebrow? · h2 · stats[] · attestHtml · slot</span></div>
      <div class="sg-demo"><TrustBand
        h2="Trusted by Australian owner builders since 2007"
        stats={[{ value: 'REG', label: 'Approved course material' }, { value: '31,000+', label: 'Students trained', numeric: true }, { value: '19', label: 'Years operating', numeric: true }, { value: '18', label: 'Modules in the course', numeric: true }]}
        attestHtml="Example attestation line. States the authority model in plain words: what the credential is, and what it is not."
      ><AnswerCapsule onDark>A representative on-dark capsule, sized for the trust band.</AnswerCapsule></TrustBand></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">TrustStats</span><span class="sg-desc">Four-up stat cells. `numeric` switches on tabular numerals; leave it off for a word.</span><span class="sg-props">items[] (value · label · numeric?)</span></div>
      <div class="sg-demo" style="background:var(--ink);padding:var(--s-lg)"><TrustStats items={[{ value: 'QBCC', label: 'Approved course material' }, { value: '31,000+', label: 'Students trained', numeric: true }, { value: '19', label: 'Years operating', numeric: true }, { value: '100%', label: 'Online and self-paced', numeric: true }]} /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">InsurancePartner</span><span class="sg-desc">Insurance cross-sell through the named partner. ABE is not a licensed insurance provider.</span><span class="sg-props">eyebrow? · heading · paras[] · cta · imgDesc · imgSpec? · imgSrc? · imgAlt? · imgRatio?</span></div>
      <div class="sg-demo"><InsurancePartner
        heading="Cover for your build, through our partner"
        paras={['As an owner builder you carry the risk on your own site, so arrange cover before work starts.', 'ABE Education is not a licensed insurance provider. Cover is arranged by the named partner.']}
        cta={{ href: '#', label: 'Get an owner builder insurance quote' }}
        imgDesc="Example insurance split image."
        imgSpec="5:4 · warm tone"
      /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">PartnerDisclosure</span><span class="sg-desc">ASQA-accredited RTO-partner disclosure (White Card etc.).</span><span class="sg-props">partner · rto · units?[] (code · name) · credential?</span></div>
      <div class="sg-demo"><PartnerDisclosure partner="Blue Dog Training" rto="31193" units={[{ code: 'CPCWHS1001', name: 'Prepare to work safely in the construction industry' }]} credential="Statement of Attainment" /><PartnerDisclosure partner="Upskill Institute" rto="45708" units={partnerUnitsEx} credential="Statement of Attainment" /></div>
    </div>
  </section>

  <!-- ===== NAVIGATION & INLINE ===== -->
  <section class="sg-group" id="g-nav">
    <h2 class="sg-group-title">Navigation & inline</h2>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">SectionWayfinder</span><span class="sg-desc">End-of-section forward-scent link with the ArrowRight fly animation.</span><span class="sg-props">label · href · onDark? · ready?</span></div>
      <div class="sg-demo sg-stack">
        <SectionWayfinder label="What it costs" href="#" />
        <SectionWayfinder label="Enrol now" href="#" ready />
      </div>
      <div class="sg-demo sg-demo--dark"><SectionWayfinder label="On a dark ground" href="#" onDark /></div>
    </div>

    <div class="sg-item">
      <div class="sg-meta"><span class="sg-name">ArrowRight</span><span class="sg-desc">Inline arrow icon; flies on hover inside btn-link / waynext.</span><span class="sg-props">no props</span></div>
      <div class="sg-demo"><a class="btn-link" href="#">See who needs a permit <ArrowRight /></a></div>
    </div>
  </section>

  <footer class="sg-foot">ABE component library · renders live from <code>src/components</code> · noindex, excluded from sitemap</footer>
</body>
</html>

<style is:global>
  body.sg { background: var(--paper-alt); }
  .sg-head { max-width: 1120px; margin: 0 auto; padding: 64px 24px 8px; }
  .sg-kicker { font-family: var(--font-mono); font-size: 11px; font-weight: 500; letter-spacing: .18em; text-transform: uppercase; color: var(--maroon); }
  .sg-head h1 { font-family: var(--font-display); font-weight: 700; font-size: clamp(34px, 5vw, 56px); letter-spacing: -.03em; line-height: 1.02; color: var(--ink); margin: 10px 0 14px; }
  .sg-head p { font-family: var(--font-body); font-size: 17px; line-height: 1.6; color: var(--ink-3); max-width: 72ch; margin: 0; }
  .sg-toc { display: flex; flex-wrap: wrap; gap: 8px 20px; margin: 24px 0 0; font-family: var(--font-mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; }
  .sg-toc a { color: var(--slate); text-decoration: none; }
  .sg-toc a:hover { color: var(--maroon); }

  .sg-group { max-width: 1120px; margin: 0 auto; padding: 40px 24px; }
  .sg-group-title { font-family: var(--font-mono); font-size: 12px; font-weight: 500; letter-spacing: .16em; text-transform: uppercase; color: var(--slate); border-bottom: 1px solid var(--rule-strong); padding-bottom: 10px; margin: 0 0 28px; }
  .sg-item { margin-bottom: 44px; }
  .sg-meta { display: flex; flex-wrap: wrap; align-items: baseline; gap: 8px 14px; margin-bottom: 12px; }
  .sg-name { font-family: var(--font-mono); font-weight: 500; font-size: 13px; color: var(--ink); background: var(--paper); border: 1px solid var(--rule-strong); border-radius: 5px; padding: 3px 9px; }
  .sg-desc { font-family: var(--font-body); font-size: 14px; color: var(--ink-3); }
  .sg-props { font-family: var(--font-mono); font-size: 11px; letter-spacing: .01em; color: var(--slate-light); flex-basis: 100%; }
  .sg-demo { background: var(--paper); border: 1px solid var(--rule); border-radius: 8px; padding: 28px; overflow: hidden; }
  .sg-demo + .sg-demo { margin-top: 12px; }
  .sg-demo--bleed { padding: 0; }
  .sg-demo--dark { background: var(--ink); }
  .sg-two { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; align-items: start; }
  .sg-stack > * + * { margin-top: 14px; }
  .sg-note-line { font-family: var(--font-mono); font-size: 12px; color: var(--slate); }
  .sg-foot { max-width: 1120px; margin: 0 auto; padding: 32px 24px 80px; font-family: var(--font-mono); font-size: 11px; letter-spacing: .04em; color: var(--slate-light); }
  @media (max-width: 640px) { .sg-two { grid-template-columns: 1fr; } }

  /* foundations */
  .sg-sub { font-family: var(--font-mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--slate-light); margin: 22px 0 12px; }
  .sg-item .sg-demo > .sg-sub:first-child { margin-top: 0; }
  .sg-swatches { display: flex; flex-wrap: wrap; gap: 14px; }
  .sg-swatch { width: 132px; }
  .sg-chip { height: 56px; border-radius: 6px; box-shadow: inset 0 0 0 1px rgba(0,0,0,.09); }
  .sg-swatch .n { display: block; font-family: var(--font-mono); font-size: 11px; color: var(--ink); margin-top: 8px; }
  .sg-swatch .hex { display: block; font-family: var(--font-mono); font-size: 10px; color: var(--slate-light); }
  .sg-swatch .note { display: block; font-family: var(--font-body); font-size: 11px; line-height: 1.35; color: var(--slate); margin-top: 3px; }
  .sg-fams { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .sg-fam { border: 1px solid var(--rule); border-radius: 8px; padding: 20px; }
  .sg-fam .aa { font-size: 46px; line-height: 1; color: var(--ink); }
  .sg-fam .fn { font-family: var(--font-mono); font-size: 12px; color: var(--ink); margin-top: 12px; }
  .sg-fam .fr { font-family: var(--font-body); font-size: 13px; color: var(--slate); }
  .sg-fam .fw { font-family: var(--font-mono); font-size: 10px; color: var(--slate-light); margin-top: 4px; }
  .sg-type-row { padding: 14px 0; border-bottom: 1px solid var(--rule); }
  .sg-type-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .sg-type-row .meta { font-family: var(--font-mono); font-size: 10px; letter-spacing: .04em; color: var(--slate-light); margin-bottom: 7px; }
  .sg-scale { display: flex; flex-direction: column; gap: 9px; }
  .sg-bar-row { display: flex; align-items: center; gap: 14px; }
  .sg-bar-row .lbl { font-family: var(--font-mono); font-size: 11px; color: var(--ink); width: 74px; flex: none; }
  .sg-bar { height: 14px; background: var(--maroon); opacity: .85; border-radius: 3px; flex: none; }
  .sg-bar-row .px { font-family: var(--font-mono); font-size: 11px; color: var(--slate-light); }
  .sg-radii { display: flex; flex-wrap: wrap; gap: 22px; }
  .sg-radius { text-align: center; }
  .sg-radius .box { width: 84px; height: 58px; background: var(--paper-warm); border: 1px solid var(--rule-strong); }
  .sg-radius .lbl { font-family: var(--font-mono); font-size: 11px; color: var(--ink); margin-top: 8px; }
  .sg-radius .note { font-family: var(--font-body); font-size: 11px; color: var(--slate); }
  .sg-btns { display: flex; flex-wrap: wrap; align-items: center; gap: 16px 24px; }
  .sg-btns .btn-link { margin-top: 0; }
  @media (max-width: 640px) { .sg-fams { grid-template-columns: 1fr; } }
</style>
