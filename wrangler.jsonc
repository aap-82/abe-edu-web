{
  // Cloudflare Workers config for a static Astro build.
  // The site is fully static (no SSR): `astro build` writes to ./dist, and the tiny
  // "main" script below only forwards to the assets binding and (on the workers.dev
  // preview host only) adds a noindex header — it does not render or fetch anything.
  // This is not an SSR adapter; Astro's output stays fully static.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "abe-edu-web",
  "compatibility_date": "2026-07-01",
  // Enable the *.workers.dev preview URL (abe-edu-web.<subdomain>.workers.dev).
  "workers_dev": true,
  "main": "worker/entry.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    // Canonical URL form is no-slash: /slug serves 200 directly from slug/index.html;
    // /slug/ redirects. See CLAUDE.md "Canonical URL form".
    "html_handling": "drop-trailing-slash",
    // An unmatched URL (no _redirects rule, no static asset) falls through to the
    // custom src/pages/404.astro (built to dist/404.html) instead of Cloudflare's
    // default asset-not-found response. Verified in the W0-7 redirect spike.
    "not_found_handling": "404-page",
    // Without this, Cloudflare serves a matching static asset directly and never invokes
    // "main" at all, silently skipping the staging noindex header below. Every request
    // routes through worker/entry.js first, which then calls env.ASSETS.fetch itself.
    "run_worker_first": true
  }
}
